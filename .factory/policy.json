{
  "executePolicy": {
    "rules": [
      {
        "decision": "deny",
        "patterns": [
          "\\b(?:npx\\s+(?:-[\\w-]+\\s+)*|pnpm\\s+dlx\\s+|bunx\\s+)?(?:mintlify|mint)(?:@[^\\s]+)?\\s+[\\'\\\"]?dev[\\'\\\"]?\\b",
          "\\bnpm\\s+run\\s+[\\'\\\"]?(dev|preview)[\\'\\\"]?\\b"
        ],
        "reason": "Mintlify previews are human-only in this repo. Use Mintlify validation or PR previews instead."
      },
      {
        "decision": "ask",
        "patterns": [
          "\\b(?:npx\\s+(?:-[\\w-]+\\s+)*|pnpm\\s+dlx\\s+|bunx\\s+)?(?:mintlify|mint)(?:@[^\\s]+)?\\s+[\\'\\\"]?login[\\'\\\"]?\\b",
          "\\bnpm\\s+run\\s+[\\'\\\"]?login[\\'\\\"]?\\b"
        ],
        "reason": "Mintlify login changes local auth state. Only run it when the user explicitly asked for authentication work."
      },
      {
        "decision": "ask",
        "patterns": [
          "\\b(?:npx\\s+(?:-[\\w-]+\\s+)*|pnpm\\s+dlx\\s+|bunx\\s+)?(?:mintlify|mint)(?:@[^\\s]+)?\\s+[\\'\\\"]?status[\\'\\\"]?\\b",
          "\\bnpm\\s+run\\s+[\\'\\\"]?status[\\'\\\"]?\\b"
        ],
        "reason": "Mintlify status depends on local authentication. Only run it when the user explicitly asked for status or authentication checks."
      }
    ]
  },
  "publicSafety": {
    "allowedFactoryRepoSlugs": ["factory-plugins"]
  }
}
