terId) {\n          setState({\n            status: PreconnectionStatus.Connected,\n            computerId: currentComputerId,\n            client,\n          });\n        }\n      } catch (error: unknown) {\n        if (!aborted && activeComputerIdRef.current === currentComputerId) {\n          setState({\n            status: PreconnectionStatus.Failed,\n            computerId: currentComputerId,\n            error:\n              error instanceof Error ? error.message : 'Connection failed',\n            recovery: getRecoveryGuidance(computer),\n          });\n        }\n      }\n    }\n\n    void attemptConnection();\n\n    return () => {\n      aborted = true;\n      if (activeComputerIdRef.current === currentComputerId) {\n        activeComputerIdRef.current = null;\n        connectionManager.disconnectMachine(currentComputerId);\n        connectionManager.removeMachine(currentComputerId);\n      }\n    };\n    // eslint-disable-next-line react-hooks/exhaustive-deps -- computer object identity changes; we key on computer.id\n  }, [computer?.id, enabled, connectionManager, retryCount]);\n\n  const retry = () => {\n    if (state.status !== PreconnectionStatus.Failed) return;\n    setRetryCount((c) => c + 1);\n  };\n\n  return { state, retry };\n}\n",
