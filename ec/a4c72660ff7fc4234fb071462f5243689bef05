            "content": "import { SessionSurface } from './enums';\n\nimport type { RoutingPolicy } from './types';\n\n// ============ Primitives ============\n\n/** Factory: always route, on every turn. */\nexport function everyTurn(): RoutingPolicy {\n  return {\n    name: 'every-turn',\n    shouldRoute: () => true,\n  };\n}\n\n/** Factory: route only on the Nth assistant turn (0-indexed). */\nexport function onceAtTurn(turn: number): RoutingPolicy {\n  return {\n    name: `once-at-turn-${turn}`,\n    shouldRoute: (ctx) => ctx.turnNumber === turn,\n  };\n}\n\n/**\n * Factory: route only if no effective model has been chosen yet.\n * This is the cheapest policy — one router call per session.\n */\nexport function onlyOnFirstCall(): RoutingPolicy {\n  return {\n    name: 'once-per-session',\n    shouldRoute: (ctx) => !ctx.hasEffectiveModel,\n  };\n}\n\n/** Factory: route only when the session surface matches. */\nexport function onlyForSurface(surface: SessionSurface): RoutingPolicy {\n  return {\n    name: `surface-${surface}`,\n    shouldRoute: (ctx) => ctx.surface === surface,\n  };\n}\n\n/** Factory: route only for sub-agent sessions (Task tool workers). */\nexport function onlyForSubAgents(): RoutingPolicy {\n  return {\n    name: 'sub-agents-only',\n    shouldRoute: (ctx) => ctx.isSubAgent,\n  };\n}\n\n/**\n * Factory: route again once the current effective model is older than the threshold.\n * Useful as an OR leg alongside onlyOnFirstCall to re-evaluate stale decisions.\n */\nexport function expireAfter(ms: number): RoutingPolicy {\n  return {\n    name: `expire-${ms}ms`,\n    shouldRoute: (ctx) => ctx.effectiveModelAge > ms,\n  };\n}\n\n/** Factory: never route — useful as a kill switch for specific surfaces. */\nexport function neverRoute(): RoutingPolicy {\n  return {\n    name: 'never',\n    shouldRoute: () => false,\n  };\n}\n\n// ============ Combinators ============\n\nexport function and(...policies: RoutingPolicy[]): RoutingPolicy {\n  return {\n    name: `and(${policies.map((p) => p.name).join(',')})`,\n    shouldRoute: (ctx) => policies.every((p) => p.shouldRoute(ctx)),\n  };\n}\n\nexport function or(...policies: RoutingPolicy[]): RoutingPolicy {\n  return {\n    name: `or(${policies.map((p) => p.name).join(',')})`,\n    shouldRoute: (ctx) => policies.some((p) => p.shouldRoute(ctx)),\n  };\n}\n\nexport function not(policy: RoutingPolicy): RoutingPolicy {\n  return {\n    name: `not(${policy.name})`,\n    shouldRoute: (ctx) => !policy.shouldRoute(ctx),\n  };\n}\n",
