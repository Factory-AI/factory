            "content": "import { MetaError } from '@factory/logging/errors';\n\nimport { ClassifierSource, TurnClassification } from '../enums';\nimport { ruleBasedClassify, RULE_BASED_CONFIDENCE } from './rule-based';\nimport { buildClassifierPrompt, CLASSIFIER_SYSTEM_PROMPT } from './prompt';\n\nimport type { ClassifierResult, ClassifierSignals, TurnClassifier } from '../types';\n\n/** Fireworks API endpoint for chat completions */\nexport const FIREWORKS_CHAT_COMPLETIONS_URL =\n  'https://api.fireworks.ai/inference/v1/chat/completions';\n\n/** Timeout for the Fireworks classifier call in milliseconds */\nexport const DEFAULT_CLASSIFIER_TIMEOUT_MS = 50;\n\n/** Default Fireworks model used for classification */\nexport const DEFAULT_CLASSIFIER_MODEL =\n  'accounts/fireworks/models/llama4-scout-instruct-basic';\n\n/**\n * Confidence score assigned to Fireworks classifier results. Set below 1.0\n * because the small model is reliable but not as precise as a large model;\n * leaving headroom lets downstream consumers reason about uncertainty.\n */\nexport const FIREWORKS_CONFIDENCE = 0.8;\n\n/**\n * Dependencies required by the Fireworks classifier. Injected so the\n * classifier can be unit-tested and run in the offline harness without\n * pulling in AWS Secrets Manager, Next.js globals, or the ambient fetch.\n */\nexport interface FireworksClassifierDeps {\n  /** fetch implementation (defaults to globalThis.fetch at construction time) */\n  fetch?: typeof fetch;\n  /** Resolves the Fireworks API key lazily so we don't require it at module load */\n  getApiKey: () => Promise<string>;\n  /** Override the classifier model (defaults to Llama 4 Scout) */\n  model?: string;\n  /** Override the timeout (defaults to 50ms) */\n  timeoutMs?: number;\n  /** Whether to fall back to the rule-based classifier on any error. Defaults to true. */\n  fallbackOnError?: boolean;\n}\n\n/**\n * Parse the Fireworks response content to extract a TurnClassification.\n * Matches COMPLEX before TRIVIAL so ambiguous outputs (containing both\n * words) err on the side of the stronger model.\n */\nexport function parseClassification(\n  responseContent: string\n): TurnClassification | null {\n  const upper = responseContent.toUpperCase().trim();\n  if (upper.includes('COMPLEX')) return TurnClassification.COMPLEX;\n  if (upper.includes('TRIVIAL')) return TurnClassification.TRIVIAL;\n  if (upper.includes('STANDARD')) return TurnClassification.STANDARD;\n  return null;\n}\n\n/**\n * Fireworks-hosted turn classifier. Implements the same TurnClassifier\n * interface as the rule-based classifier so routers and offline tools can\n * swap them freely.\n */\nexport class FireworksTurnClassifier implements TurnClassifier {\n  readonly name = 'fireworks';\n\n  private readonly fetchImpl: typeof fetch;\n\n  private readonly getApiKey: () => Promise<string>;\n\n  private readonly model: string;\n\n  private readonly timeoutMs: number;\n\n  private readonly fallbackOnError: boolean;\n\n  constructor(deps: FireworksClassifierDeps) {\n    this.fetchImpl = deps.fetch ?? globalThis.fetch.bind(globalThis);\n    this.getApiKey = deps.getApiKey;\n    this.model = deps.model ?? DEFAULT_CLASSIFIER_MODEL;\n    this.timeoutMs = deps.timeoutMs ?? DEFAULT_CLASSIFIER_TIMEOUT_MS;\n    this.fallbackOnError = deps.fallbackOnError ?? true;\n  }\n\n  async classify(signals: ClassifierSignals): Promise<ClassifierResult> {\n    const started = performance.now();\n    try {\n      const classification = await this.callFireworks(signals);\n      return {\n        classification,\n        confidence: FIREWORKS_CONFIDENCE,\n        latencyMs: performance.now() - started,\n        source: ClassifierSource.Fireworks,\n      };\n    } catch (error) {\n      if (!this.fallbackOnError) throw error;\n      const classification = ruleBasedClassify(signals);\n      return {\n        classification,\n        confidence: RULE_BASED_CONFIDENCE,\n        latencyMs: performance.now() - started,\n        source: ClassifierSource.RuleBased,\n      };\n    }\n  }\n\n  private async callFireworks(\n    signals: ClassifierSignals\n  ): Promise<TurnClassification> {\n    const apiKey = await this.getApiKey();\n    const prompt = buildClassifierPrompt(signals);\n\n    const controller = new AbortController();\n    const timeoutId = setTimeout(() => controller.abort(), this.timeoutMs);\n\n    try {\n      const response = await this.fetchImpl(FIREWORKS_CHAT_COMPLETIONS_URL, {\n        method: 'POST',\n        headers: {\n          Authorization: `Bearer ${apiKey}`,\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({\n          model: this.model,\n          messages: [\n            { role: 'system', content: CLASSIFIER_SYSTEM_PROMPT },\n            { role: 'user', content: prompt },\n          ],\n          max_tokens: 10,\n          temperature: 0,\n        }),\n        signal: controller.signal,\n      });\n\n      if (!response.ok) {\n        throw new MetaError('Fireworks classifier returned non-OK status', {\n          statusCode: String(response.status),\n        });\n      }\n\n      const json = (await response.json()) as {\n        choices?: Array<{ message?: { content?: string } }>;\n      };\n      const content = json.choices?.[0]?.message?.content ?? '';\n      const classification = parseClassification(content);\n      if (!classification) {\n        throw new MetaError('Unable to parse Fireworks classifier output', {\n          contentSoFar: content,\n        });\n      }\n      return classification;\n    } finally {\n      clearTimeout(timeoutId);\n    }\n  }\n}\n",
