            "content": "import type {\n  ClassifierSource,\n  RoutingDecisionSource,\n  SessionSurface,\n  TurnClassification,\n} from './enums';\nimport type {\n  ApiProvider,\n  ModelID,\n  ReasoningEffort,\n} from '@factory/common/llm';\n\n/**\n * A single message harvested from the conversation history and fed to\n * the classifier's session context. Free-form text only — tool calls\n * and images are surfaced via other signal fields.\n */\nexport interface RecentMessage {\n  role: 'user' | 'assistant';\n  text: string;\n}\n\n/**\n * All signals a classifier can see about the current turn.\n *\n * Extend this interface (with optional fields) instead of introducing\n * parallel shapes so new signals work everywhere automatically. The\n * session-context section of the dynamic prompt is assembled from\n * these fields in `buildSessionContextXml`.\n */\nexport interface ClassifierSignals {\n  /** Session ID — used for fixture lookup and metrics correlation. */\n  sessionId: string;\n  /** Which surface is driving the session (exec, interactive, sub-agent) */\n  surface: SessionSurface;\n  /** True when this session is a sub-agent (e.g. Task tool worker). */\n  isSubAgentSession: boolean;\n  /** Parent session ID when this is a sub-agent session. */\n  parentSessionId?: string;\n  /** 0-indexed assistant turn number within the session. */\n  turnCount: number;\n  /** Whether any message in the conversation contains an image attachment. */\n  hasImages: boolean;\n\n  /** Tool calls from the recent turns, newest last. */\n  recentToolCalls: ReadonlyArray<{\n    name: string;\n    status: 'success' | 'error';\n  }>;\n  /** Pre-derived flag that any recent tool call ended in error. */\n  hasFailedToolCalls?: boolean;\n\n  /**\n   * The current (most recent) user prompt with any\n   * `<system-reminder>` tags stripped out. Empty string if the\n   * session has no user turns yet.\n   */\n  currentUserMessage: string;\n  /**\n   * The very first user prompt in the session, sanitized the same\n   * way as `currentUserMessage`. Useful for long sessions where the\n   * current turn is a follow-up to an earlier high-level goal.\n   */\n  firstUserMessage?: string;\n  /**\n   * Raw system-info block captured once from the session's initial\n   * `<system-reminder>` tag (OS, cwd, AGENTS.md-derived guidelines,\n   * etc.). Classifiers use this to detect \"which stack is the user\n   * working on\" signals.\n   */\n  systemInfo?: string;\n  /**\n   * Most recent conversation messages (user + assistant), oldest\n   * first. Typically excludes the final user turn (that lives in\n   * `currentUserMessage`). Bounded by `RECENT_MESSAGE_COUNT` before\n   * budget packing drops any that don't fit.\n   */\n  recentMessages?: ReadonlyArray<RecentMessage>;\n  /** Short rolling summary emitted by a prior compaction, if any. */\n  conversationSummary?: string;\n}\n\n/**\n * A model that is a routing candidate. The classifier assigns a score\n * to each candidate; the selector then picks a winner using cost as a\n * tiebreaker.\n */\nexport interface CandidateModel {\n  modelId: ModelID;\n  apiProvider: ApiProvider;\n  reasoningEffort: ReasoningEffort;\n  /**\n   * Short (1-3 sentence) capability description surfaced to the\n   * scoring LLM. Should cover: strengths, weaknesses, typical\n   * latency, image support, best-suited task shapes.\n   */\n  shortDescription: string;\n  /**\n   * Relative input cost used by the selector to break ties between\n   * candidates that both clear QUALITY_THRESHOLD. Higher = more\n   * expensive. Not shown to the classifier — the classifier must\n   * judge capability on its own without cost bleed-through.\n   */\n  inputCostPer1M: number;\n  /** Relative output cost, same semantics as inputCostPer1M. */\n  outputCostPer1M: number;\n  /** Whether this model can process image inputs. */\n  supportsImages: boolean;\n}\n\n/**\n * Per-candidate score produced by a classifier.\n * `score` is the probability [0, 1] that this model can solve the\n * turn well with minimal back-and-forth. A score of 0 hard-rejects\n * the candidate (e.g. no image support when the turn has images).\n */\nexport interface CandidateScore {\n  modelId: ModelID;\n  score: number;\n}\n\n/**\n * Result of classifying a turn against a set of candidate models.\n */\nexport interface ClassifierResult {\n  /**\n   * One entry per candidate passed in to `classify()`, in the same\n   * order. Every candidate always has a score — a hard reject is\n   * represented by a score of 0, not by omission.\n   */\n  scores: CandidateScore[];\n  /** Optional 1-2 sentence explanation from the classifier. */\n  reasoning?: string;\n  /**\n   * High-level classification bucket, kept for backwards-compatible\n   * metrics and logs. Classifiers that don't naturally produce one\n   * may omit the field.\n   */\n  classification?: TurnClassification;\n  /** Time taken by the classifier in milliseconds. */\n  latencyMs: number;\n  /** Where the classification came from (for metrics / debugging). */\n  source: ClassifierSource;\n}\n\n/**\n * Provider-agnostic turn classifier.\n *\n * Implementations must be pure / side-effect-free so they can run in\n * prod, unit tests, and the offline router-eval harness\n * interchangeably.\n */\nexport interface TurnClassifier {\n  readonly name: string;\n  classify(\n    signals: ClassifierSignals,\n    candidates: readonly CandidateModel[]\n  ): Promise<ClassifierResult>;\n}\n\n/**\n * Minimal OpenAI-compatible chat message shape used by the classifier\n * abstraction. Only `role` and `content` are needed.\n */\nexport interface OpenAIChatMessage {\n  role: 'system' | 'user' | 'assistant';\n  content: string;\n}\n\n/**\n * JSON-schema descriptor passed through to the OpenAI structured\n * output feature (`response_format: { type: 'json_schema', ... }`).\n *\n * `schema` is the raw JSON-schema object (strict mode compliant).\n */\nexport interface JsonSchemaSpec {\n  name: string;\n  strict: boolean;\n  schema: Record<string, unknown>;\n}\n\nexport type OpenAIResponseFormat =\n  | { type: 'json_object' }\n  | { type: 'json_schema'; jsonSchema: JsonSchemaSpec };\n\n/**\n * Provider-agnostic chat completion request shape. Adapters translate\n * this to the real OpenAI SDK call (backend) or a raw fetch against\n * the Factory proxy (CLI).\n */\nexport interface OpenAIChatCompletionRequest {\n  model: string;\n  messages: OpenAIChatMessage[];\n  responseFormat?: OpenAIResponseFormat;\n  maxCompletionTokens?: number;\n  /** GPT-5 family reasoning budget toggle; `minimal` = skip thinking. */\n  reasoningEffort?: 'minimal' | 'low' | 'medium' | 'high';\n  temperature?: number;\n}\n\nexport interface OpenAIChatCompletionResponse {\n  /** Raw assistant text content from the first choice. */\n  content: string;\n  usage?: {\n    promptTokens?: number;\n    completionTokens?: number;\n    cachedPromptTokens?: number;\n  };\n}\n\nexport interface OpenAIChatCompletionClient {\n  complete(\n    request: OpenAIChatCompletionRequest\n  ): Promise<OpenAIChatCompletionResponse>;\n}\n\n/**\n * Dependencies required by the GPT-5.4-mini classifier.\n * Everything is injected so the classifier can run in unit tests, the\n * offline router-eval harness, and both client and server runtimes.\n */\nexport interface Gpt5MiniClassifierDeps {\n  /** OpenAI-compatible chat client (SDK-backed or proxy-backed). */\n  client: OpenAIChatCompletionClient;\n  /** Override the classifier model id (defaults to `gpt-5.4-mini`). */\n  modelId?: string;\n  /**\n   * Whether to fall back to a rule-based score emission on any error.\n   * Defaults to `true` so routing stays resilient.\n   */\n  fallbackOnError?: boolean;\n  /** Optional clock override for deterministic latency measurements. */\n  now?: () => number;\n}\n\n/**\n * A concrete model choice returned by the selector.\n */\nexport interface ModelOption {\n  modelId: ModelID;\n  apiProvider: ApiProvider;\n  reasoningEffort: ReasoningEffort;\n  /** 0 = primary choice, 1+ = ordered fallbacks */\n  rank: number;\n  /** Human-readable explanation of why this option was picked */\n  rationale: string;\n  /** Score that won (or was highest) for this pick. */\n  score?: number;\n}\n\n/**\n * Decision returned by a ModelRouter.\n */\nexport interface RoutingDecision {\n  /** Ordered list of model options. options[0] is the primary choice. */\n  options: ModelOption[];\n  classification?: TurnClassification;\n  classifierResult: ClassifierResult;\n  /** ISO timestamp when the decision was made. */\n  decidedAt: string;\n  /** Where the decision was computed (client or server). */\n  decidedBy: RoutingDecisionSource;\n  /** How long the agent may reuse this decision (ms). */\n  ttlMs: number;\n  /** Session the decision applies to. */\n  sessionId: string;\n}\n\n/**\n * A model selector turns a classifier result + candidate list into an\n * ordered list of concrete model options.\n */\nexport interface ModelSelector {\n  readonly name: string;\n  select(\n    result: ClassifierResult,\n    signals: ClassifierSignals,\n    candidates: readonly CandidateModel[]\n  ): ModelOption[];\n}\n\n/**\n * Provider-agnostic interface for model routing. Implementations may\n * be local (runs classifier + selector in-process) or remote (calls\n * the backend router API).\n */\nexport interface ModelRouter {\n  readonly name: string;\n  route(signals: ClassifierSignals): Promise<RoutingDecision>;\n}\n\n/**\n * Context passed to a RoutingPolicy at every turn. The agent\n * populates this at call time from SessionService state; policies\n * themselves must be pure functions of the context.\n */\nexport interface RoutingPolicyContext {\n  surface: SessionSurface;\n  isSubAgent: boolean;\n  /** 0-indexed assistant turn number within the session. */\n  turnNumber: number;\n  /** Whether an effective model is already cached on the session. */\n  hasEffectiveModel: boolean;\n  /** Milliseconds since the current effective model was chosen. */\n  effectiveModelAge: number;\n}\n\n/**\n * Decides whether *this turn* should consult the model router.\n */\nexport interface RoutingPolicy {\n  readonly name: string;\n  shouldRoute(ctx: RoutingPolicyContext): boolean;\n}\n\n/**\n * Options for constructing a LocalRouter.\n */\nexport interface LocalRouterDeps {\n  classifier: TurnClassifier;\n  selector: ModelSelector;\n  /** Candidate models the classifier scores and the selector picks from. */\n  candidates: readonly CandidateModel[];\n  /** How long a decision should be considered valid (ms). Default 60s. */\n  ttlMs?: number;\n  /** Where the decision originated (\"client\" or \"server\"). Default \"client\". */\n  decidedBy?: RoutingDecisionSource;\n  /** Optional clock override for deterministic tests. */\n  now?: () => Date;\n}\n\n/** Minimal fetcher shape — matches `fetch` well enough. */\nexport type RouterFetcher = (\n  url: string,\n  init: RequestInit\n) => Promise<Response>;\n\nexport interface RemoteApiRouterDeps {\n  fetcher: RouterFetcher;\n  endpoint?: string;\n  fallbackOnError?: boolean;\n  now?: () => Date;\n}\n\nexport interface RouterRequestBody {\n  signals: ClassifierSignals;\n}\n",
