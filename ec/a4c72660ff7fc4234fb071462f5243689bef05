            "content": "import { customFetch } from '@factory/droid-core/api/fetch';\nimport {\n  DEFAULT_CANDIDATES,\n  DEFAULT_DECISION_TTL_MS,\n  Gpt5MiniTaskClassifier,\n  Router,\n  RoutingDecisionSource,\n  defaultModelSelector,\n} from '@factory/droid-core/model-router';\nimport { getEnvironment } from '@factory/environment';\nimport { MetaError } from '@factory/logging/errors';\n\nimport type { ModelRoutingConfig } from '@/services/FeatureFlagService';\n\nimport type {\n  ModelRouter,\n  OpenAIChatCompletionClient,\n  OpenAIChatCompletionRequest,\n  OpenAIChatCompletionResponse,\n  OpenAIResponseFormat,\n} from '@factory/droid-core/model-router';\n\n/** Path of the Factory LLM proxy's OpenAI-compatible endpoint. */\nconst CLI_CLASSIFIER_ENDPOINT = '/api/llm/o/v1/chat/completions';\n\n/** Shape of the upstream OpenAI chat-completions response we care about. */\ninterface ChatCompletionsResponse {\n  choices?: Array<{ message?: { content?: string | null } }>;\n  usage?: {\n    prompt_tokens?: number;\n    completion_tokens?: number;\n    prompt_tokens_details?: { cached_tokens?: number };\n  };\n}\n\n/**\n * Translate the shared {@link OpenAIResponseFormat} shape to the wire\n * format expected by the OpenAI chat-completions REST endpoint (and\n * the Factory LLM proxy, which mirrors it).\n */\nfunction toWireResponseFormat(\n  responseFormat: OpenAIResponseFormat | undefined\n): Record<string, unknown> | undefined {\n  if (!responseFormat) return undefined;\n  if (responseFormat.type === 'json_object') {\n    return { type: 'json_object' };\n  }\n  return {\n    type: 'json_schema',\n    json_schema: {\n      name: responseFormat.jsonSchema.name,\n      strict: responseFormat.jsonSchema.strict,\n      schema: responseFormat.jsonSchema.schema,\n    },\n  };\n}\n\n/**\n * Build an {@link OpenAIChatCompletionClient} that POSTs to the\n * Factory LLM proxy's OpenAI-compatible endpoint. Auth is injected\n * automatically by {@link customFetch}.\n */\nfunction createFactoryProxyChatClient(): OpenAIChatCompletionClient {\n  const url = `${getEnvironment().apiBaseUrl}${CLI_CLASSIFIER_ENDPOINT}`;\n  return {\n    complete: async (\n      req: OpenAIChatCompletionRequest\n    ): Promise<OpenAIChatCompletionResponse> => {\n      const body: Record<string, unknown> = {\n        model: req.model,\n        messages: req.messages,\n        max_completion_tokens: req.maxCompletionTokens,\n        temperature: req.temperature,\n      };\n      const wireResponseFormat = toWireResponseFormat(req.responseFormat);\n      if (wireResponseFormat) body.response_format = wireResponseFormat;\n      if (req.reasoningEffort) body.reasoning_effort = req.reasoningEffort;\n\n      const response = await customFetch(url, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify(body),\n      });\n      if (!response.ok) {\n        throw new MetaError('Router classifier proxy call failed', {\n          statusCode: String(response.status),\n        });\n      }\n      const payload = (await response.json()) as ChatCompletionsResponse;\n      const content = payload.choices?.[0]?.message?.content ?? '';\n      return {\n        content,\n        usage: {\n          promptTokens: payload.usage?.prompt_tokens,\n          completionTokens: payload.usage?.completion_tokens,\n          cachedPromptTokens:\n            payload.usage?.prompt_tokens_details?.cached_tokens,\n        },\n      };\n    },\n  };\n}\n\n/**\n * Build the one-and-only {@link ModelRouter} used by the CLI.\n *\n * The router runs in-process with a {@link Gpt5MiniTaskClassifier}\n * whose OpenAI client targets the Factory LLM proxy. The backend\n * mounts the exact same Router + classifier pair in its\n * `/api/llm/router/select-model` endpoint — the only difference is\n * that the backend's classifier calls the OpenAI SDK directly.\n *\n * Returns `null` only when future experiments explicitly disable\n * routing; currently it alw