          "input": {
            "content": "/**\n * Offline routing evaluation harness for the Factory agent model router.\n *\n * Reads JSONL fixtures from a path (default: evals/router/fixtures.jsonl),\n * runs the unified GPT-5.4-mini classifier + selector against each entry,\n * and reports which primary model the router picked per case. Measures\n * per-fixture score distributions, selection accuracy against an\n * optional `expectedPrimary` label, and average classifier latency.\n *\n * Same code that runs in production via @factory/droid-core/model-router,\n * which is the entire point: any improvement we measure here applies\n * directly to the prod router.\n *\n * Usage:\n *   OPENAI_API_KEY=sk-... npm run router-eval\n *   npm run router-eval -- --fixtures evals/router/fixtures.jsonl\n *   npm run router-eval -- --openai-api-key sk-...\n */\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport process from 'node:process';\n\nimport {\n  DEFAULT_CANDIDATES,\n  DefaultModelSelector,\n  Gpt5MiniTaskClassifier,\n  QUALITY_THRESHOLD,\n  Router,\n  RoutingDecisionSource,\n  SessionSurface,\n  TurnClassification,\n} from '@factory/droid-core/model-router';\nimport { MetaError } from '@factory/logging/errors';\n\nimport type { ModelID } from '@factory/common/llm';\nimport type {\n  CandidateModel,\n  ClassifierSignals,\n  ModelRouter,\n  OpenAIChatCompletionClient,\n  OpenAIChatCompletionRequest,\n  OpenAIChatCompletionResponse,\n  RoutingDecision,\n} from '@factory/droid-core/model-router';\n\ninterface FixtureEntry {\n  id: string;\n  /** Optional legacy bucket label, for backwards compat with older fixtures. */\n  expected?: TurnClassification;\n  /** Optional expected primary model id (preferred over `expected`). */\n  expectedPrimary?: ModelID;\n  signals: ClassifierSignals;\n}\n\ninterface CliArgs {\n  fixtures: string;\n  openaiApiKey?: string;\n  jsonOutput: boolean;\n}\n\nfunction parseArgs(argv: string[]): CliArgs {\n  const args: CliArgs = {\n    fixtures: 'evals/router/fixtures.jsonl',\n    openaiApiKey: process.env.OPENAI_API_KEY,\n    jsonOutput: false,\n  };\n\n  for (let i = 0; i < argv.length; i += 1) {\n    const arg = argv[i];\n    if (arg === '--fixtures' && argv[i + 1]) {\n      args.fixtures = argv[i + 1]!;\n      i += 1;\n    } else if (arg === '--openai-api-key' && argv[i + 1]) {\n      args.openaiApiKey = argv[i + 1]!;\n      i += 1;\n    } else if (arg === '--json') {\n      args.jsonOutput = true;\n    }\n  }\n  return args;\n}\n\nfunction readFixtures(filePath: string): FixtureEntry[] {\n  if (!fs.existsSync(filePath)) {\n    throw new MetaError('Fixture file not found', { filePath });\n  }\n  const raw = fs.readFileSync(filePath, 'utf8');\n  return raw\n    .split('\\n')\n    .filter((line) => line.trim().length > 0)\n    .map((line, index) => {\n      try {\n        const obj = JSON.parse(line) as Partial<FixtureEntry>;\n        if (!obj.id || !obj.signals || !obj.signals.sessionId) {\n          throw new MetaError(\n            'Fixture missing one of required fields: id, signals.sessionId',\n            { value: `line ${index + 1}` }\n          );\n        }\n        const signals: ClassifierSignals = {\n          ...obj.signals,\n          recentToolCalls: obj.signals.recentToolCalls ?? [],\n          surface: obj.signals.surface ?? SessionSurface.InteractiveTui,\n          isSubAgentSession: obj.signals.isSubAgentSession ?? false,\n          turnCount: obj.signals.turnCount ?? 0,\n          hasImages: obj.signals.hasImages ?? false,\n          currentUserMessage: obj.signals.currentUserMessage ?? '',\n        };\n        return {\n          id: obj.id,\n          expected: obj.expected,\n          expectedPrimary: obj.expectedPrimary,\n          signals,\n        };\n      } catch (error) {\n        throw new MetaError('Failed to parse fixture line', {\n          value: `line ${index + 1}`,\n          cause: (error as Error).message,\n        });\n      }\n    });\n}\n\nfunction toOpenAIResponseForm