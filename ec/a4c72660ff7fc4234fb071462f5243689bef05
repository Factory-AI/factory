  expect(onlyForSubAgents.shouldRoute(ctx({ isSubAgent: true }))).toBe(true);\n      expect(onlyForSubAgents.shouldRoute(ctx({ isSubAgent: false }))).toBe(false);\n    });\n  });\n\n  describe('expireAfter', () => {\n    it('routes when the effective model is older than the threshold', () => {\n      const policy = expireAfter(60_000);\n      expect(policy.shouldRoute(ctx({ effectiveModelAge: 30_000 }))).toBe(false);\n      expect(policy.shouldRoute(ctx({ effectiveModelAge: 90_000 }))).toBe(true);\n      expect(policy.shouldRoute(ctx({ effectiveModelAge: Infinity }))).toBe(true);\n    });\n  });\n\n  describe('neverRoute', () => {\n    it('never fires', () => {\n      expect(neverRoute.shouldRoute(ctx())).toBe(false);\n    });\n  });\n});\n\ndescribe('RoutingPolicy combinators', () => {\n  describe('and', () => {\n    it('requires all children to fire', () => {\n      const policy = and(onlyForSurface(SessionSurface.Exec), everyTurn);\n      expect(policy.shouldRoute(ctx({ surface: SessionSurface.Exec }))).toBe(true);\n      expect(\n        policy.shouldRoute(ctx({ surface: SessionSurface.InteractiveTui }))\n      ).toBe(false);\n    });\n  });\n\n  describe('or', () => {\n    it('fires if any child fires', () => {\n      const policy = or(\n        onceAtTurn(0),\n        expireAfter(60_000)\n      );\n      expect(\n        policy.shouldRoute(ctx({ turnNumber: 0, effectiveModelAge: 0 }))\n      ).toBe(true);\n      expect(\n        policy.shouldRoute(ctx({ turnNumber: 5, effectiveModelAge: 120_000 }))\n      ).toBe(true);\n      expect(\n        policy.shouldRoute(ctx({ turnNumber: 5, effectiveModelAge: 10_000 }))\n      ).toBe(false);\n    });\n  });\n\n  describe('not', () => {\n    it('inverts a policy', () => {\n      const policy = not(onlyForSubAgents);\n      expect(policy.shouldRoute(ctx({ isSubAgent: false }))).toBe(true);\n      expect(policy.shouldRoute(ctx({ isSubAgent: true }))).toBe(false);\n    });\n  });\n});\n",
