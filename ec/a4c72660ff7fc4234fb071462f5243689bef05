"  Actual total cost (routed):  ${actual_total:.2f}\")\nprint(f\"  Hypothetical all-Opus cost:  ${opus_total:.2f}\")\nprint(f\"  Savings:                     ${savings:.2f} ({savings/opus_total*100:.1f}%)\")\nprint()\n\n# Kimi misroutes (failed kimi tasks)\nkimi_fails = [t for t in completed if t[\"model\"] == \"kimi\" and t[\"reward\"] == 0]\nprint(f\"=== KIMI FAILURES ({len(kimi_fails)} tasks) ===\")\nfor t in sorted(kimi_fails, key=lambda x: x[\"task\"]):\n    c = cost(t)\n    oc = cost_with_model(t, \"opus\")\n    print(f\"  {t['task']:45s} ${c:.3f} (opus=${oc:.2f}) turns={t['turns']}\")\nprint()\n\n# Opus failures\nopus_fails = [t for t in completed if t[\"model\"] == \"opus\" and t[\"reward\"] == 0]\nprint(f\"=== OPUS FAILURES ({len(opus_fails)} tasks) ===\")\nfor t in sorted(opus_fails, key=lambda x: x[\"task\"]):\n    c = cost(t)\n    print(f\"  {t['task']:45s} ${c:.3f}  turns={t['turns']}\")\nprint()\n\n# Top 10 most expensive\nprint(\"=== TOP 10 MOST EXPENSIVE TASKS ===\")\nfor t in sorted(completed, key=lambda x: cost(x), reverse=True)[:10]:\n    c = cost(t)\n    status = \"PASS\" if t[\"reward\"] == 1 else \"FAIL\"\n    print(f\"  {t['model']:5s} {status} ${c:7.2f}  {t['task']:40s} turns={t['turns']}\")\nprint()\n\n# Top 10 cheapest passes\nprint(\"=== TOP 10 CHEAPEST PASSES ===\")\npasses = [t for t in completed if t[\"reward\"] == 1]\nfor t in sorted(passes, key=lambda x: cost(x))[:10]:\n    c = cost(t)\n    oc = cost_with_model(t, \"opus\")\n    print(f\"  {t['model']:5s} ${c:7.3f} (opus=${oc:.2f})  {t['task']:40s} turns={t['turns']}\")\n",
