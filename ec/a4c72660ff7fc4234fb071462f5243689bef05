            "content": "/**\n * Offline classifier evaluation harness for the auto model router.\n *\n * Reads JSONL fixtures from a path (default: evals/router/fixtures.jsonl),\n * runs the configured classifier against each entry, and reports per-class\n * precision/recall plus overall accuracy.\n *\n * Same code that runs in production via @factory/droid-core/model-router,\n * which is the entire point: any improvement we measure here applies\n * directly to the prod router.\n *\n * Usage:\n *   npm run router-eval -- --fixtures evals/router/fixtures.jsonl\n *   npm run router-eval -- --classifier rule-based\n *   npm run router-eval -- --classifier fireworks --fireworks-api-key sk-…\n */\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport process from 'node:process';\n\nimport {\n  FireworksTurnClassifier,\n  RuleBasedTurnClassifier,\n  SessionSurface,\n  TurnClassification,\n} from '@factory/droid-core/model-router';\n\nimport type {\n  ClassifierResult,\n  ClassifierSignals,\n  TurnClassifier,\n} from '@factory/droid-core/model-router';\n\ninterface FixtureEntry {\n  id: string;\n  expected: TurnClassification;\n  signals: ClassifierSignals;\n}\n\ninterface CliArgs {\n  fixtures: string;\n  classifier: 'rule-based' | 'fireworks';\n  fireworksApiKey?: string;\n  jsonOutput: boolean;\n}\n\nfunction parseArgs(argv: string[]): CliArgs {\n  const args: CliArgs = {\n    fixtures: 'evals/router/fixtures.jsonl',\n    classifier: 'rule-based',\n    fireworksApiKey: process.env.FACTORY_FIREWORKS_API_KEY,\n    jsonOutput: false,\n  };\n\n  for (let i = 0; i < argv.length; i += 1) {\n    const arg = argv[i];\n    if (arg === '--fixtures' && argv[i + 1]) {\n      args.fixtures = argv[i + 1];\n      i += 1;\n    } else if (arg === '--classifier' && argv[i + 1]) {\n      const value = argv[i + 1];\n      if (value !== 'rule-based' && value !== 'fireworks') {\n        throw new Error(\n          `--classifier must be 'rule-based' or 'fireworks', got: ${value}`\n