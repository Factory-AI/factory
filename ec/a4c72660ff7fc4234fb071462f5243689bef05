            "content": "import { QUALITY_THRESHOLD } from '../constants';\nimport { buildSessionContextXml } from '../context';\n\nimport type {\n  CandidateModel,\n  ClassifierSignals,\n  JsonSchemaSpec,\n} from '../types';\n\n/**\n * Build the static system prompt sent on every classification call.\n *\n * MUST be deterministic for a given candidate list so OpenAI's\n * automatic prompt cache returns a hit on subsequent calls. The\n * candidate cards deliberately omit cost information — cost is a\n * selector-side concern and must not bleed into capability scoring.\n *\n * The output contract is NOT embedded as prose because the classifier\n * enforces structured JSON via `response_format: { type: 'json_schema' }`\n * on the OpenAI API — so the model receives the schema as metadata and\n * cannot drift off-spec.\n */\nexport function buildStaticClassifierSystemPrompt(\n  candidates: readonly CandidateModel[]\n): string {\n  const candidateBlocks = candidates\n    .map((candidate, index) => {\n      const imageTag = candidate.supportsImages\n        ? 'handles images'\n        : 'cannot see images';\n      return [\n        `<model index=\"${index}\" id=\"${candidate.modelId}\">`,\n        `  <apiProvider>${candidate.apiProvider}</apiProvider>`,\n        `  <imageSupport>${imageTag}</imageSupport>`,\n        `  <description>${candidate.shortDescription}</description>`,\n        `</model>`,\n      ].join('\\n');\n    })\n    .join('\\n');\n\n  return [\n    'You are a task routing classifier for the Factory AI coding agent.',\n    'Every turn you receive (1) a fixed list of candidate models and',\n    \"(2) structured context about the user's current turn in the\",\n    '`<session>` block. Score each candidate with the probability that',\n    'it can complete the turn SUCCESSFULLY with MINIMAL BACK-AND-FORTH',\n    'OR ERROR. You are not allowed to pick a winner yourself — the',\n    'downstream selector handles cost/quality tradeoffs using your',\n    'scores. Ignore cost and latency entirely; judge capability only.',\n    '',\n    '# Candidate models',\n    '',\n    candidateBlocks,\n    '',\n    '# Scoring rubric',\n    '',\n    'For each candidate, emit a score in the [0.0, 1.0] range:',\n    '',\n    '- 1.0 — Will almost certainly solve the task on the first attempt.',\n    '- 0.9 — Very likely to solve it cleanly.',\n    '- 0.8 — Likely success; minor follow-up edits possible.',\n    `- 0.7 — Borderline; acceptable but may need a nudge. This is the`,\n    `  QUALITY_THRESHOLD (${QUALITY_THRESHOLD}) the selector uses to`,\n    '  decide whether cheaper models are viable.',\n    '- 0.5 — Coin-flip; expect rework.',\n    '- 0.3 — Likely to miss the spec or thrash.',\n    '- 0.0 — Hard reject (cannot complete; e.g. image-only tasks on a',\n    '  text-only model). Hard rejects MUST be exactly 0.0.',\n    '',\n    'Scoring heuristics (apply in order):',\n    '',\n    '1. Hard capability gates first. If a candidate lacks image support',\n    '   and the turn has images, score it 0.0.',\n    '2. Reward weaker models on simple work. A 0.9 for a small model on',\n    '   a single-file edit is better than 0.95 for the flagship — the',\n    '   flagship is still a viable fallback because its score will be',\n    '   high too.',\n    '3. Penalize weaker models on complex work: multi-file refactors,',\n    '   architecture decisions, subtle debugging, and error recovery',\n    '   usually warrant 0.3-0.5 on standard-tier models and 0.9+ on',\n    '   premium-tier models.',\n    '4. Long reasoning chains (step-by-step debugging, plan-then-',\n    '   execute) favor the strongest model available.',\n    '5. Read-only / Q&A turns (Grep, Read, LS, short questions) are',\n    '   cheap-model territory — score 0.85-0.95 for standard models.',\n    '6. Turns that already show failed tool calls or error recovery in',\n    '   the history lean complex; bias toward the premium model.',\n    '7. Be conservative when unsure. If in doubt between 0.6 and 0.8,',\n    '   pick 0.6 for the weaker model and 0.9 for the stronger one.',\n    '',\n    'When reading `<session>`, pay attention in this order:',\n    'current_user_message → recent_tool_calls → first_user_message →',\n    'recent_messages → conversation_summary → system_info. The',\n    'current_user_message is always the primary signal.',\n  ].join('\\n');\n}\n\n/**\n * Build the dynamic per-turn user prompt. Contains only the packed\n * session context wrapped in XML, followed by an explicit hard divider\n * and a short task instruction so the model cannot confuse session\n * content with classifier instructions.\n */\nexport function buildDynamicTaskUserPrompt(\n  signals: ClassifierSignals\n): string {\n  const sessionXml = buildSessionContextXml(signals);\n  return [\n    sessionXml,\n    '',\n    '---',\n    '',\n    '# Task',\n    '',\n    'Score each candidate model per the rubric in the system prompt,',\n    'based ONLY on the `<session>` content above. Respond with JSON',\n    'that matches the provided schema.',\n  ].join('\\n');\n}\n\n/**\n * Build the JSON-schema descriptor passed to OpenAI's structured\n * output feature so GPT-5.4-mini is constrained to emit the exact\n * shape our parser expects. Generated per-call so new candidate lists\n * need no extra wiring.\n *\n * Strict mode requires all properties to be in `required` and all\n * objects to set `additionalProperties: false`.\n */\nexport function buildClassifierJsonSchema(\n  candidates: readonly CandidateModel[],\n  schemaName: string\n): JsonSchemaSpec {\n  const scoreProperties: Record<string, unknown> = {};\n  const scoreRequired: string[] = [];\n  for (const candidate of candidates) {\n    scoreProperties[candidate.modelId] = { type: 'number' };\n    scoreRequired.push(candidate.modelId);\n  }\n  return {\n    name: schemaName,\n    strict: true,\n    schema: {\n      type: 'object',\n      properties: {\n        scores: {\n          type: 'object',\n          properties: scoreProperties,\n          required: scoreRequired,\n          additionalProperties: false,\n        },\n        classification: {\n          type: 'string',\n          enum: ['TRIVIAL', 'STANDARD', 'COMPLEX'],\n        },\n        reasoning: { type: 'string' },\n      },\n      required: ['scores', 'classification', 'reasoning'],\n      additionalProperties: false,\n    },\n  };\n}\n",
