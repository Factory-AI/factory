            "content": "import { ClassifierSource } from '../enums';\n\nimport type {\n  CandidateModel,\n  CandidateScore,\n  ClassifierResult,\n  ClassifierSignals,\n  TurnClassifier,\n} from '../types';\nimport type { ModelID } from '@factory/common/llm';\n\n/**\n * A classifier backed by a static lookup table, keyed by sessionId.\n * Used in unit tests and the offline router-eval harness to get\n * deterministic scores without hitting an LLM.\n *\n * Each fixture entry is `Partial<Record<ModelID, number>>` so tests can\n * specify scores for a subset of the candidate list; any missing\n * candidate defaults to the fallback score.\n */\nexport type FixtureScoreTable = Partial<Record<ModelID, number>>;\n\nexport class FixtureTurnClassifier implements TurnClassifier {\n  readonly name = 'fixture';\n\n  private readonly table: Map<string, FixtureScoreTable>;\n\n  private readonly fallback: FixtureScoreTable;\n\n  constructor(\n    entries: Iterable<readonly [string, FixtureScoreTable]>,\n    fallback: FixtureScoreTable = {}\n  ) {\n    this.table = new Map(entries);\n    this.fallback = fallback;\n  }\n\n  async classify(\n    signals: ClassifierSignals,\n    candidates: readonly CandidateModel[]\n  ): Promise<ClassifierResult> {\n    const started = performance.now();\n    const lookup = this.table.get(signals.sessionId) ?? this.fallback;\n    const scores: CandidateScore[] = candidates.map((candidate) => {\n      if (signals.hasImages && !candidate.supportsImages) {\n        return { modelId: candidate.modelId, score: 0 };\n      }\n      const raw = lookup[candidate.modelId];\n      return {\n        modelId: candidate.modelId,\n        score: typeof raw === 'number' ? clamp(raw) : 0,\n      };\n    });\n    return {\n      scores,\n      latencyMs: performance.now() - started,\n      source: ClassifierSource.Fixture,\n    };\n  }\n}\n\nfunction clamp(n: number): number {\n  if (n <= 0) return 0;\n  if (n >= 1) return 1;\n  return n;\n}\n",
