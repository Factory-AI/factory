ue;\n    for (const block of message.content) {\n      if (block.type === MessageContentBlockType.Image) {\n        hasImages = true;\n      }\n      if (block.type === MessageContentBlockType.ToolUse) {\n        toolCalls.push({ name: block.name, status: 'success' });\n      }\n      if (block.type === MessageContentBlockType.ToolResult) {\n        const last = toolCalls[toolCalls.length - 1];\n        if (last && 'isError' in block && block.isError) {\n          last.status = 'error';\n        }\n      }\n    }\n  }\n\n  // Pass 2: walk forward to capture the first user message + initial\n  // system info. The very first user turn usually wraps its real\n  // prompt next to a `<system-reminder>` block carrying OS, cwd,\n  // AGENTS.md, and friends.\n  let systemInfo: string | undefined;\n  let firstUserMessage: string | undefined;\n  for (const message of conversationHistory) {\n    if (message.role !== MessageRole.User) continue;\n    const fullText = extractMessageText(message);\n    if (!systemInfo) {\n      const reminders = extractSystemReminderBlocks(fullText);\n      if (reminders.length > 0) {\n        systemInfo = reminders.join('\\n\\n');\n      }\n    }\n    const userText = stripSystemReminders(fullText);\n    if (userText) {\n      firstUserMessage = userText;\n      break;\n    }\n  }\n\n  // Pass 3: walk backward to find the CURRENT user message (latest\n  // non-empty user turn after stripping system reminders).\n  let currentUserMessage = '';\n  for (let i = conversationHistory.length - 1; i >= 0; i -= 1) {\n    const message = conversationHistory[i];\n    if (message.role !== MessageRole.User) continue;\n    const userText = stripSystemReminders(extractMessageText(message));\n    if (userText) {\n      currentUserMessage = userText;\n      break;\n    }\n  }\n\n  // Pass 4: collect recent messages (user + assistant) oldest-first,\n  // bounded by RECENT_MESSAGE_COUNT. The current user message is\n  // excluded here since it's already surfaced sep