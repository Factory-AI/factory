OSTS = Object.fromEntries(\n  MODEL_IDS.map((id) => [id, relativeCost(id, MIN_COST)])\n);\n\nfunction utility(score: number, relCost: number, alpha: number, gamma: number): number {\n  if (score <= 0) return 0;\n  return score - alpha * score ** (1 + gamma) * relCost;\n}\n\n/** Log-sum-exp for numerical stability. */\nfunction logsumexp(values: number[]): number {\n  const max = Math.max(...values);\n  if (!isFinite(max)) return -Infinity;\n  let sum = 0;\n  for (const v of values) sum += Math.exp(v - max);\n  return max + Math.log(sum);\n}\n\ninterface LossAndGrad {\n  loss: number;\n  accuracy: number;\n  dAlpha: number;\n  dGamma: number;\n}\n\nfunction computeLossAndGrad(\n  samples: Sample[],\n  alpha: number,\n  gamma: number,\n  tau: number\n): LossAndGrad {\n  let totalLoss = 0;\n  let correct = 0;\n  let dAlpha = 0;\n  let dGamma = 0;\n\n  for (const sample of samples) {\n    // Compute utilities\n    const utilities: Record<string, number> = {};\n    for (const id of MODEL_IDS) {\n      const s = sample.scores[id] ?? 0;\n      utilities[id] = utility(s, REL_COSTS[id]!, alpha, gamma);\n    }\n\n    // Softmax probabilities\n    const logits = MODEL_IDS.map((id) => tau * utilities[id]!);\n    const lse = logsumexp(logits);\n    const probs: Record<string, number> = {};\n    for (let j = 0; j < MODEL_IDS.length; j++) {\n      probs[MODEL_IDS[j]!] = Math.exp(logits[j]! - lse);\n    }\n\n    // Cross-entropy loss for this sample\n    const truthProb = probs[sample.truth] ?? 1e-12;\n    totalLoss -= Math.log(Math.max(truthProb, 1e-12));\n\n    // Accuracy\n    let bestId = MODEL_IDS[0]!;\n    let bestU = -Infinity;\n    for (const id of MODEL_IDS) {\n      if (utilities[id]! > bestU) {\n        bestU = utilities[id]!;\n        bestId = id;\n      }\n    }\n    if (bestId === sample.truth) correct++;\n\n    // Analytical gradients\n    // dL/dparam = tau * sum_c (P(c) - 1[c=truth]) * du_c/dparam\n    for (const id of MODEL_IDS) {\n      const s = sample.scores[id] ?? 0;\n      if (s <= 0) continue;\n      const rc = REL_COSTS[id]!;\n      const indicator = id === sample.truth ? 1 : 0;\n      const softmaxGrad = tau * (probs[id]! - indicator);\n\n      // du/dalpha = -s^(1+gamma) * rc\n      const duDalpha = -(s ** (1 + gamma)) * rc;\n      // du/dgamma = -alpha * s^(1+gamma) * ln(s) * rc\n      const duDgamma = -alpha * (s ** (1 + gamma)) * Math.log(s) * rc;\n\n      dAlpha += softmaxGrad * duDalpha;\n      dGamma += softmaxGrad * duDgamma;\n    }\n  }\n\n  const n = samples.length;\n  return {\n    loss: totalLoss / n,\n    accuracy: correct / n,\n    dAlpha: dAlpha / n,\n    dGamma: dGamma / n,\n  };\n}\n\n// ── Optimizer ──\n\ninterface OptResult {\n  alpha: number;\n  gamma: number;\n  loss: number;\n  accuracy: number;\n}\n\nfunction optimize(\n  samples: Sample[],\n  opts: {\n    initAlpha?: number;\n    initGamma?: number;\n    tau?: number;\n    lr?: number;\n    steps?: number;\n    logInterval?: number;\n  } = {}\n): OptResult {\n  let alpha = opts.initAlpha ?? 0.3;\n  let gamma = opts.initGamma ?? 2.0;\n  const tau = opts.tau ?? 15;\n  const lr = opts.lr ?? 0.01;\n  const steps = opts.steps ?? 2000;\n  const logInterval = opts.logInterval ?? 200;\n\n  let bestResult: OptResult = { alpha, gamma, loss: Infinity, accuracy: 0 };\n\n  process.stdout.write(\n    `Optimizing: ${samples.length} samples, τ=${tau}, lr=${lr}, ${steps} steps\\n`\n  );\n  process.stdout.write(\n    `Initial: α=${alpha.toFixed(4)}, γ=${gamma.toFixed(4)}\\n\\n`\n  );\n\n  for (let step = 0; step <= steps; step++) {\n    const { loss, accuracy, dAlpha, dGamma } = computeLossAndGrad(\n      samples,\n      alpha,\n      gamma,\n      tau\n    );\n\n    if (step % logInterval === 0 || step === steps) {\n      // Compute the implicit crossover threshold for reporting\n      const opusScore = 0.96; // typical\n      const opusRelCost = REL_COSTS['claude-opus-4-6']!;\n      const opusU = utility(opusScore, opusRelCost, alpha, gamma);\n      process.stdout.write(\n        `  step=${String(step).padStart(5)}  loss=${loss.toFixed(4)}  acc=${(accuracy * 100).toFixed(1)}%  α=${alpha.toFixed(4)}  γ=${gamma.toFixed(4)}  crossover≈${opusU.toFixed(3)}  |∇|=${Math.sqrt(dAlpha ** 2 + dGamma ** 2).toFixed(4)}\\n`\n      );\n    }\n\n    if (loss < bestResult.loss) {\n      bestResult = { alpha, gamma, loss, accuracy };\n    }\n\n    // Gradient descent update\n    alpha -= lr * dAlpha;\n    gamma -= lr * dGamma;\n\n    // Clamp to valid ranges\n    alpha = Math.max(0.01, alpha);\n    gamma = Math.max(0.1, gamma);\n  }\n\n  return bestResult;\n}\n\n// ── Main ──\n\nfunction main(): void {\n  let scoresPath = '/tmp/eval-scores-3t.json';\n  let tau = 15;\n  let lr = 0.01;\n  let steps = 2000;\n  const argv = process.argv.slice(2);\n\n  for (let i = 0; i < argv.length; i++) {\n    if (argv[i] === '--scores' && argv[i + 1]) {\n      scoresPath = argv[i + 1]!;\n      i++;\n    } else if (argv[i] === '--tau' && argv[i + 1]) {\n      tau = Number(argv[i + 1]!);\n      i++;\n    } else if (argv[i] === '--lr' && argv[i + 1]) {\n      lr = Number(argv[i + 1]!);\n      i++;\n    } else if (argv[i] === '--steps' && argv[i + 1]) {\n      steps = Number(argv[i + 1]!);\n      i++;\n    }\n  }\n\n  const samples = loadSamples(scoresPath);\n  process.stdout.write(`Loaded ${samples.length} samples from ${scoresPath}\\n`);\n\n  // Run at multiple tau values to check sensitivity\n  const taus = [tau];\n  for (const t of taus) {\n    process.stdout.write(`\\n${'='.repeat(60)}\\n`);\n    const best = optimize(samples, { tau: t, lr, steps });\n    process.stdout.write(\n      `\\nBest: α=${best.alpha.toFixed(4)}, γ=${best.gamma.toFixed(4)}, ` +\n        `loss=${best.loss.toFixed(4)}, acc=${(best.accuracy * 100).toFixed(1)}%\\n`\n    );\n\n    // Print the implied crossover threshold\n    const opusScore = 0.96;\n    const opusU = utility(\n      opusScore,\n      REL_COSTS['claude-opus-4-6']!,\n      best.alpha,\n      best.gamma\n    );\n    process.stdout.write(\n      `Implied crossover: kimi needs score > ${opusU.toFixed(3)} to win\\n`\n    );\n  }\n}\n\nmain();\n",
