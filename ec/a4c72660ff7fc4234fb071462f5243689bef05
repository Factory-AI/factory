            "content": "import {\n  CHARS_PER_TOKEN_ESTIMATE,\n  CONTEXT_LIMIT_TOKENS,\n  KEEP_HEAD_LENGTH,\n  KEEP_TAIL_LENGTH,\n  MAX_RECENT_TOOL_CALLS,\n} from './constants';\n\nimport type { ClassifierSignals, RecentMessage } from './types';\n\n/**\n * Approximate token count for an arbitrary string. Used only for\n * budget enforcement on the dynamic session context — the classifier\n * still receives raw text. Conservative (4 chars/token) to over-reserve\n * rather than under-reserve.\n */\nexport function estimateTokenCount(text: string): number {\n  return Math.ceil(text.length / CHARS_PER_TOKEN_ESTIMATE);\n}\n\n/**\n * Trim a long string by preserving `headLen` characters from the start,\n * `tailLen` characters from the end, and replacing the middle with a\n * truncation marker. Returns the original string unchanged when it\n * already fits. The marker explicitly reports how many chars were\n * omitted so the scorer can calibrate its confidence.\n */\nexport function trimMessageHeadTail(\n  text: string,\n  headLen: number = KEEP_HEAD_LENGTH,\n  tailLen: number = KEEP_TAIL_LENGTH\n): string {\n  if (text.length <= headLen + tailLen + 40) return text;\n  const head = text.slice(0, headLen);\n  const tail = text.slice(text.length - tailLen);\n  const omitted = text.length - headLen - tailLen;\n  return `${head}\\n... [${omitted} chars truncated] ...\\n${tail}`;\n}\n\n/**\n * A renderable section of the session context. Sections are packed\n * into the dynamic user prompt in priority order (lowest `priority`\n * wins when budget is tight), then rendered into the final string in\n * `outputOrder`.\n */\ninterface SessionContextSection {\n  /** Stable ID used for pack/output ordering. */\n  id: SessionSectionId;\n  /** Pack priority (lower = included first when budget is tight). */\n  priority: number;\n  /** XML-wrapped rendering of the section. */\n  xml: string;\n}\n\ntype SessionSectionId =\n  | 'turn_context'\n  | 'current_user_message'\n  | 'recent_tool_calls'\n  | 'system_info'\n  | 'first_user_message'\n  | 'conversation_summary'\n  | 'recent_messages';\n\n/**\n * Order in which sections appear in the final packed XML. Kept\n * separate from pack priority so we can evaluate inclusion greedily\n * while still producing a deterministic, readable layout. Current\n * user message is last for emphasis.\n */\nconst OUTPUT_ORDER: SessionSectionId[] = [\n  'turn_context',\n  'system_info',\n  'conversation_summary',\n  'first_user_message',\n  'recent_messages',\n  'recent_tool_calls',\n  'current_user_message',\n];\n\nfunction indent(text: string, prefix: string): string {\n  return text\n    .split('\\n')\n    .map((line) => `${prefix}${line}`)\n    .join('\\n');\n}\n\nfunction renderTurnContext(signals: ClassifierSignals): string {\n  const hasFailedTools =\n    signals.hasFailedToolCalls ??\n    signals.recentToolCalls.some((tc) => tc.status === 'error');\n  const lines = [\n    '<turn_context>',\n    `  turn_number: ${signals.turnCount}`,\n    `  surface: ${signals.surface}`,\n    `  sub_agent: ${signals.isSubAgentSession ? 'yes' : 'no'}`,\n    `  images_present: ${signals.hasImages ? 'yes' : 'no'}`,\n    `  has_failed_tool_calls: ${hasFailedTools ? 'yes' : 'no'}`,\n    '</turn_context>',\n  ];\n  return lines.join('\\n');\n}\n\nfunction renderSimpleWrapped(\n  tag: SessionSectionId,\n  body: string,\n  headLen: number,\n  tailLen: number\n): string {\n  const trimmed = trimMessageHeadTail(body, headLen, tailLen);\n  return `<${tag}>\\n${indent(trimmed, '  ')}\\n</${tag}>`;\n}\n\nfunction renderRecentMessages(messages: readonly RecentMessage[]): string {\n  const blocks = messages.map((message) => {\n    const trimmed = trimMessageHeadTail(message.text);\n    return [\n      `  <message role=\"${message.role}\">`,\n      indent(trimmed, '    '),\n      '  </message>',\n    ].join('\\n');\n  });\n  return ['<recent_messages>', ...blocks, '</recent_messages>'].join('\\n');\n}\n\nfunction renderRecentToolCalls(\n  toolCalls: ClassifierSignals['recentToolCalls']\n): string {\n  const slice = toolCalls.slice(-MAX_RECENT_TOOL_CALLS);\n  const lines = slice.map((tc) => `  ${tc.name}: ${tc.status}`);\n  return ['<recent_tool_calls>', ...lines, '</recent_tool_calls>'].join('\\n');\n}\n\n/**\n * Assemble every candidate section for the given signals, with stable\n * priority metadata. Only sections with non-empty content are emitted.\n */\nfunction collectSections(signals: ClassifierSignals): SessionContextSection[] {\n  const sections: SessionContextSection[] = [];\n\n  // Priority 0: turn context — always included, tiny\n  sections.push({\n    id: 'turn_context',\n    priority: 0,\n    xml: renderTurnContext(signals),\n  });\n\n  // Priority 1: current user message — always the most important thing\n  sections.push({\n    id: 'current_user_message',\n    priority: 1,\n    xml: renderSimpleWrapped(\n      'current_user_message',\n      signals.currentUserMessage || '[empty]',\n      KEEP_HEAD_LENGTH,\n      KEEP_TAIL_LENGTH\n    ),\n  });\n\n  // Priority 2: recent tool calls (tiny, high signal for complexity)\n  if (signals.recentToolCalls.length > 0) {\n    sections.push({\n      id: 'recent_tool_calls',\n      priority: 2,\n      xml: renderRecentToolCalls(signals.recentToolCalls),\n    });\n  }\n\n  // Priority 3: system info (useful but bulky; keep head/tail)\n  if (signals.systemInfo) {\n    sections.push({\n      id: 'system_info',\n      priority: 3,\n      xml: renderSimpleWrapped(\n        'system_info',\n        signals.systemInfo,\n        KEEP_HEAD_LENGTH,\n        KEEP_TAIL_LENGTH\n      ),\n    });\n  }\n\n  // Priority 4: first user message (the session's original \"why\")\n  if (\n    signals.firstUserMessage &&\n    signals.firstUserMessage !== signals.currentUserMessage\n  ) {\n    sections.push({\n      id: 'first_user_message',\n      priority: 4,\n      xml: renderSimpleWrapped(\n        'first_user_message',\n        signals.firstUserMessage,\n        KEEP_HEAD_LENGTH,\n        KEEP_TAIL_LENGTH\n      ),\n    });\n  }\n\n  // Priority 5: conversation summary from compaction\n  if (signals.conversationSummary) {\n    sections.push({\n      id: 'conversation_summary',\n      priority: 5,\n      xml: renderSimpleWrapped(\n        'conversation_summary',\n        signals.conversationSummary,\n        KEEP_HEAD_LENGTH,\n        KEEP_TAIL_LENGTH\n      ),\n    });\n  }\n\n  // Priority 6: recent messages — bulkiest, dropped first under pressure\n  if (signals.recentMessages && signals.recentMessages.length > 0) {\n    sections.push({\n      id: 'recent_messages',\n      priority: 6,\n      xml: renderRecentMessages(signals.recentMessages),\n    });\n  }\n\n  return sections;\n}\n\n/**\n * Pack the signal sections into a single `<session>…</session>` XML\n * block constrained by `budgetTokens`. Algorithm:\n *\n *   1. Collect every candidate section with priority metadata.\n *   2. Walk sections in ascending priority and include the next one if\n *      it still fits in the remaining budget; otherwise skip it.\n *   3. Render the included sections in `OUTPUT_ORDER` so the resulting\n *      XML has a deterministic, readable shape regardless of which\n *      sections survived.\n *\n * Adding a new section is a matter of appending a branch in\n * `collectSections()` and putting its ID in `OUTPUT_ORDER`.\n */\nexport function buildSessionContextXml(\n  signals: ClassifierSignals,\n  budgetTokens: number = CONTEXT_LIMIT_TOKENS\n): string {\n  const sections = collectSections(signals);\n  const sortedByPriority = [...sections].sort(\n    (a, b) => a.priority - b.priority\n  );\n\n  let used = 0;\n  const included = new Map<SessionSectionId, string>();\n  for (const section of sortedByPriority) {\n    const tokens = estimateTokenCount(section.xml);\n    if (used + tokens > budgetTokens) continue;\n    included.set(section.id, section.xml);\n    used += tokens;\n  }\n\n  const ordered = OUTPUT_ORDER.map((id) => included.get(id)).filter(\n    (xml): xml is string => xml !== undefined\n  );\n  return ['<session>', ...ordered, '</session>'].join('\\n\\n');\n}\n",
