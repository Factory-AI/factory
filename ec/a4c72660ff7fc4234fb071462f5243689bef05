            "content": "import { RoutingDecisionSource } from '../enums';\n\nimport type { ClassifierSignals, ModelSelector, RoutingDecision, TurnClassifier } from '../types';\nimport type { ModelRouter } from './types';\n\n/** Default TTL for a routing decision (ms) — 1 minute. */\nexport const DEFAULT_DECISION_TTL_MS = 60_000;\n\n/**\n * Options for constructing a LocalRouter.\n */\nexport interface LocalRouterDeps {\n  classifier: TurnClassifier;\n  selector: ModelSelector;\n  /** How long a decision should be considered valid (ms). Default 60s. */\n  ttlMs?: number;\n  /** Where the decision originated (\"client\" or \"server\"). Default \"client\". */\n  decidedBy?: RoutingDecisionSource;\n  /** Optional clock override for deterministic tests */\n  now?: () => Date;\n}\n\n/**\n * A router that runs the classifier and selector in the current process.\n * Used both on the CLI (client-side experiments) and on the backend\n * (server-side endpoint implementation).\n */\nexport class LocalRouter implements ModelRouter {\n  readonly name = 'local';\n\n  private readonly classifier: TurnClassifier;\n\n  private readonly selector: ModelSelector;\n\n  private readonly ttlMs: number;\n\n  private readonly decidedBy: RoutingDecisionSource;\n\n  private readonly now: () => Date;\n\n  constructor(deps: LocalRouterDeps) {\n    this.classifier = deps.classifier;\n    this.selector = deps.selector;\n    this.ttlMs = deps.ttlMs ?? DEFAULT_DECISION_TTL_MS;\n    this.decidedBy = deps.decidedBy ?? RoutingDecisionSource.Client;\n    this.now = deps.now ?? (() => new Date());\n  }\n\n  async route(signals: ClassifierSignals): Promise<RoutingDecision> {\n    const classifierResult = await this.classifier.classify(signals);\n    const options = this.selector.select(classifierResult, signals);\n    return {\n      options,\n      classification: classifierResult.classification,\n      classifierResult,\n      decidedAt: this.now().toISOString(),\n      decidedBy: this.decidedBy,\n     