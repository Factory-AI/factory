            "content": "/**\n * Build router-eval fixtures from a real benchmark run directory by\n * reconstructing ClassifierSignals through the same canonical code\n * path the CLI uses at runtime.\n *\n * For each task directory:\n *   1. Loads the session JSONL (agent/sessions/…/*.jsonl)\n *   2. Parses the first user message into ConversationMessage[]\n *   3. Runs buildClassifierSignalsFromHistory (from droid-core)\n *   4. Cross-references with the headroom TSV for ground-truth labels\n *   5. Emits a fixture with the full reconstructed signals\n *\n * Usage:\n *   npx tsx src/router-eval/build-fixtures-from-run.ts \\\n *     --run-dir ~/src/factory/factory-evals/jobs/router-tb2-full-v2_2026-04-10__01-55-18 \\\n *     --headroom ~/src/factory/factory-evals/analysis_output/opus-vs-kimi-headroom.tsv \\\n *     --output ../../evals/router/headroom-fixtures.jsonl\n */\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport process from 'node:process';\n\nimport {\n  SessionSurface,\n  buildClassifierSignalsFromHistory,\n} from '@factory/droid-core/model-router';\n\nimport type {\n  ClassifierSignals,\n  ConversationMessage,\n} from '@factory/droid-core/model-router';\n\n// ── Headroom TSV ──\n\ninterface HeadroomRow {\n  dataset: string;\n  taskId: string;\n  opusPassRate: number | null;\n  opusTrials: number;\n  kimiPassRate: number | null;\n  kimiTrials: number;\n}\n\nfunction parseFloatOrNull(v: string): number | null {\n  if (!v || !v.trim()) return null;\n  const n = Number(v);\n  return Number.isFinite(n) ? n : null;\n}\n\nfunction readHeadroomTsv(filePath: string): Map<string, HeadroomRow> {\n  const raw = fs.readFileSync(filePath, 'utf8');\n  const lines = raw.split('\\n').filter((l) => l.trim().length > 0);\n  const header = lines[0]!.split('\\t');\n  const idx = (name: string) => header.indexOf(name);\n  const map = new Map<string, HeadroomRow>();\n  for (let i = 1; i < lines.length; i += 1) {\n    const cells = lines[i]!.split('\\t');\n    const row: HeadroomRow = {\n      dataset: cells[idx('dataset')]!,\n      taskId: cells[idx('task_id')]!,\n      opusPassRate: parseFloatOrNull(cells[idx('opus_pass_rate')] ?? ''),\n      opusTrials: Number(cells[idx('opus_trials')] ?? '0'),\n      kimiPassRate: parseFloatOrNull(cells[idx('kimi_pass_rate')] ?? ''),\n      kimiTrials: Number(cells[idx('kimi_trials')] ?? '0'),\n    };\n    map.set(row.taskId, row);\n  }\n  return map;\n}\n\n// ── Labeling ──\n\nconst MIN_TRIALS = 5;\nconst KIMI_TOLERANCE = 0.1;\nconst KIMI_MIN_PASS = 0.65;\nconst OPUS_HEADROOM = 0.25;\nconst OPUS_MIN_PASS = 0.4;\n\nfunction labelRow(row: HeadroomRow): 'kimi-k2.5' | 'claude-opus-4-6' | null {\n  if (row.opusPassRate === null || row.kimiPassRate === null) return null;\n  if (row.opusTrials < MIN_TRIALS || row.kimiTrials < MIN_TRIALS) return null;\n  if (row.opusPassRate === 0 && row.kimiPassRate === 0) return null;\n  const delta = row.opusPassRate - row.kimiPassRate;\n  if (row.kimiPassRate >= KIMI_MIN_PASS && delta <= KIMI_TOLERANCE)\n    return 'kimi-k2.5';\n  if (delta >= OPUS_HEADROOM && row.opusPassRate >= OPUS_MIN_PASS)\n    return 'claude-opus-4-6';\n  return null;\n}\n\n// ── Session JSONL → ConversationMessage[] ──\n\ninterface SessionJsonlMessageEvent {\n  type: 'message';\n  id: string;\n  timestamp: string;\n  message: {\n    role: string;\n    content: Array<{\n      type: string;\n      text?: string;\n      name?: string;\n      isError?: boolean;\n      is_error?: boolean;\n    }>;\n  };\n}\n\nfunction parseSessionJsonl(filePath: string): ConversationMessage[] {\n  const raw = fs.readFileSync(filePath, 'utf8');\n  const lines = raw.split('\\n').filter((l) => l.trim().length > 0);\n  const messages: ConversationMessage[] = [];\n\n  for (const line of lines) {\n    const event = JSON.parse(line) as Record<string, unknown>;\n    if (event.type !== 'message') continue;\n    const msgEvent = event as unknown as SessionJsonlMessageEvent;\n    const msg = msgEvent.message;\n    if (!msg?.role || !Array.isArray(msg.content)) continue;\n\n    const role =\n      msg.role === 'user'\n        ? ('user' as const)\n        : msg.role === 'assistant'\n          ? ('assistant' as const)\n          : ('tool' as const);\n\n    messages.push({\n      role,\n      content: msg.content.map((b) => ({\n        type: b.type,\n        text: b.text,\n        name: b.name,\n        isError: b.isError ?? b.is_error,\n      })),\n    });\n  }\n  return messages;\n}\n\n// ── Routing info from droid log ──\n\ninterface RoutingInfo {\n  modelId: string;\n  classification: string;\n  source: string;\n  latencyMs: number;\n}\n\nfunction extractRoutingFromLog(logPath: string): RoutingInfo | null {\n  if (!fs.existsSync(logPath)) return null;\n  const lines = fs.readFileSync(logPath, 'utf8').split('\\n');\n  for (const line of lines) {\n    if (!line.includes('Model-Router') || !line.includes('Routed')) continue;\n    const ctxMatch = line.match(/Context: ({.*})$/);\n    if (!ctxMatch) continue;\n    try {\n      const ctx = JSON.parse(ctxMatch[1]!) as {\n        value?: {\n          modelId?: string;\n          classification?: string;\n          source?: string;\n          latencyMs?: number;\n        };\n      };\n      if (ctx.value?.modelId) {\n        return {\n          modelId: ctx.value.modelId,\n          classification: ctx.value.classification ?? 'unknown',\n          source: ctx.value.source ?? 'unknown',\n          latencyMs: ctx.value.latencyMs ?? 0,\n        };\n      }\n    } catch {\n      continue;\n    }\n  }\n  return null;\n}\n\n// ── Build signals per task ──\n\ninterface TaskData {\n  taskId: string;\n  signals: ClassifierSignals;\n  routing: RoutingInfo | null;\n  reward: number;\n}\n\nfunction findSessionJsonl(taskDir: string): string | null {\n  const sessionsDir = path.join(taskDir, 'agent/sessions');\n  if (!fs.existsSync(sessionsDir)) return null;\n  const walk = (dir: string): string | null => {\n    for (const entry of fs.readdirSync(