            "content": "import { ModelID } from '@factory/common/llm';\n\nimport { DEFAULT_CANDIDATES } from '../candidates';\nimport { ClassifierSource, SessionSurface, TurnClassification } from '../enums';\nimport { Gpt5MiniTaskClassifier, parseGpt5MiniResponse } from './gpt5-mini';\n\nimport type {\n  ClassifierSignals,\n  OpenAIChatCompletionClient,\n  OpenAIChatCompletionRequest,\n  OpenAIChatCompletionResponse,\n} from '../types';\n\nfunction signals(\n  overrides: Partial<ClassifierSignals> = {}\n): ClassifierSignals {\n  return {\n    lastUserMessage: 'hi',\n    recentToolCalls: [],\n    hasImages: false,\n    turnCount: 1,\n    surface: SessionSurface.InteractiveTui,\n    isSubAgentSession: false,\n    sessionId: 's1',\n    ...overrides,\n  };\n}\n\nfunction mockClient(\n  content: string,\n  capture?: (req: OpenAIChatCompletionRequest) => void\n): OpenAIChatCompletionClient {\n  return {\n    complete: async (req) => {\n      capture?.(req);\n      const response: OpenAIChatCompletionResponse = { content };\n      return response;\n    },\n  };\n}\n\ndescribe('parseGpt5MiniResponse', () => {\n  it('parses a clean JSON object', () => {\n    const payload = parseGpt5MiniResponse(\n      JSON.stringify({\n        scores: {\n          [ModelID.MINIMAX_M2_5]: 0.9,\n          [ModelID.CLAUDE_OPUS_4_6]: 0.95,\n        },\n        classification: 'TRIVIAL',\n        reasoning: 'Short read-only ask.',\n      })\n    );\n    expect(payload.scores[ModelID.MINIMAX_M2_5]).toBe(0.9);\n    expect(payload.scores[ModelID.CLAUDE_OPUS_4_6]).toBe(0.95);\n    expect(payload.classification).toBe('TRIVIAL');\n    expect(payload.reasoning).toBe('Short read-only ask.');\n  });\n\n  it('strips surrounding markdown fences', () => {\n    const raw =\n      '```json\\n{\"scores\":{\"minimax-m2.5\":0.8,\"claude-opus-4-6\":0.9}}\\n```';\n    const payload = parseGpt5MiniResponse(raw);\n    expect(payload.scores['minimax-m2.5']).toBe(0.8);\n    expect(payload.scores['claude-opus-4-6']).toBe(0.9);\n  });\n\n  it('extracts JSON from surrounding prose', () => {\n    const raw =\n      'Here is my answer: {\"scores\":{\"minimax-m2.5\":0.5,\"claude-opus-4-6\":0.95}}. Done.';\n    const payload = parseGpt5MiniResponse(raw);\n    expect(payload.scores['minimax-m2.5']).toBe(0.5);\n  });\n\n  it('clamps out-of-range scores', () => {\n    const payload = parseGpt5MiniResponse(\n      JSON.stringify({\n        scores: { 'minimax-m2.5': 1.6, 'claude-opus-4-6': -0.2 },\n      })\n    );\n    expect(payload.scores['minimax-m2.5']).toBe(1);\n    expect(payload.scores['claude-opus-4-6']).toBe(0);\n  });\n\n  it('throws when the payload is not JSON at all', () => {\n    expect(() => parseGpt5MiniResponse('I refuse to answer.')).toThrow();\n  });\n\n  it('throws when scores is missing', () => {\n    expect(() =>\n      parseGpt5MiniResponse(JSON.stringify({ classification: 'TRIVIAL' }))\n    ).toThrow(/missing/i);\n  });\n});\n\ndescribe('Gpt5MiniTaskClassifier', () => {\n  it('calls the OpenAI-compatible client with the right shape', async () => {\n    let capturedRequest: OpenAIChatCompletionRequest | undefined;\n    const client = mockClient(\n      JSON.stringify({\n        scores: {\n          [ModelID.MINIMAX_M2_5]: 0.9,\n          [ModelID.CLAUDE_OPUS_4_6]: 0.95,\n        },\n        classification: 'TRIVIAL',\n        reasoning: 'simple lookup',\n      }),\n      (req) => {\n        capturedRequest = req;\n      }\n    );\n\n    const classifier = new Gpt5MiniTaskClassifier({ client });\n    const result = await classifier.classify(signals(), DEFAULT_CANDIDATES);\n\n    expect(capturedRequest).toBeDefined();\n    expect(capturedRequest?.model).toBe('gpt-5.4-mini');\n    expect(capturedRequest?.reasoningEffort).toBe('minimal');\n    expect(capturedRequest?.responseFormat).toBe('json_object');\n    expect(capturedRequest?.temperature).toBe(0);\n    expect(capturedRequest?.messages).toHaveLength(2);\n    expect(capturedRequest?.messages[0]?.role).toBe('system');\n    expect(capturedRequest?.messages[0]?.content).toContain(\n      '# Candidate models'\n    );\n    expect(capturedRequest?.messages[1]?.role).toBe('user');\n    expect(capturedRequest?.messages[1]?.content).toContain('# User message');\n\n    expect(result.source).toBe(ClassifierSource.Gpt5Mini);\n    expect(result.scores).toHaveLength(DEFAULT_CANDIDATES.length);\n    expect(result.classification).toBe(TurnClassification.TRIVIAL);\n    expect(result.reasoning).toBe('simple lookup');\n  });\n\n  it('assembles scores for all candidates, defaulting missing ones to zero', async () => {\n    const client = mockClient(\n      JSON.stringify({\n        scores: { [ModelID.MINIMAX_M2_5]: 0.8 }, // Opus missing\n      })\n    );\n    const classifier = new Gpt5MiniTaskClassifier({ client });\n    const result = await classifier.classify(signals(), DEFAULT_CANDIDATES);\n    const minimax = result.scores.find(\n      (s) => s.modelId === ModelID.MINIMAX_M2_5\n    );\n    const opus = result.scores.find(\n      (s) => s.modelId === ModelID.CLAUDE_OPUS_4_6\n    );\n    expect(minimax?.score).toBe(0.8);\n    expect(opus?.score).toBe(0);\n  });\n\n  it('hard rejects image-blind candidates on image turns before even calling the model', async () => {\n    const client = mockClient(\n      JSON.stringify({\n        scores: {\n          [ModelID.MINIMAX_M2_5]: 0.9, // Model ignores the image warning\n          [ModelID.CLAUDE_OPUS_4_6]: 0.95,\n        },\n      })\n    );\n    const classifier = new Gpt5MiniTaskClassifier({ client });\n    const result = await classifier.classify(\n      signals({ hasImages: true }),\n      DEFAULT_CANDIDATES\n    );\n    const minimax = result.scores.find(\n      (s) => s.modelId === ModelID.MINIMAX_M2_5\n    );\n    expect(minimax?.score).toBe(0);\n  });\n\n  it('falls back to rule-based scores on parse error', async () => {\n    const client = mockClient('not-json');\n    const classifier = new Gpt5MiniTaskClassifier({ client });\n    const result = await classifier.classify(\n      signals({ lastUserMessage: 'refactor auth' }),\n      DEFAULT_CANDIDATES\n    );\n    expect(result.source).toBe(ClassifierSource.RuleBased);\n    expect(result.scores).toHaveLength(DEFAULT_CANDIDATES.length);\n    expect(result.classification).toBe(TurnClassification.COMPLEX);\n  });\n\n  it('propagates errors when fallbackOnError is disabled', async () => {\n    const client = mockClient('garbage');\n    const classifier = new Gpt5MiniTaskClassifier({\n      client,\n      fallbackOnError: false,\n    });\n    await expect(\n      classifier.classify(signals(), DEFAULT_CANDIDATES)\n    ).rejects.toThrow();\n  });\n\n  it('throws immediately when no candidates are provided', async () => {\n    const client = mockClient('{}');\n    const classifier = new Gpt5MiniTaskClassifier({\n      client,\n      fallbackOnError: false,\n    });\n    await expect(classifier.classify(signals(), [])).rejects.toThrow(\n      /at least one candidate/\n    );\n  });\n});\n",
