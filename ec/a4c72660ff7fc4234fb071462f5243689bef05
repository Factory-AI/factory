            "content": "import { RULE_BASED_CONFIDENCE } from '../constants';\nimport {\n  ClassifierSource,\n  SessionSurface,\n  TurnClassification,\n} from '../enums';\n\nimport type {\n  ClassifierResult,\n  ClassifierSignals,\n  TurnClassifier,\n} from '../types';\n\n/** Read-only tool names that indicate a trivial turn */\nconst READ_ONLY_TOOLS = new Set([\n  'Read',\n  'Grep',\n  'Glob',\n  'LS',\n  'WebSearch',\n  'FetchUrl',\n]);\n\n/** Keywords that suggest a complex task */\nconst COMPLEXITY_KEYWORDS = [\n  'refactor',\n  'architect',\n  'debug',\n  'migrate',\n  'redesign',\n  'rewrite',\n  'overhaul',\n  'restructure',\n];\n\n/** Edit-like tool names that count against the complex-edit threshold */\nconst EDIT_TOOL_NAMES = new Set(['Edit', 'Create', 'MultiEdit']);\n\n/** Maximum message length for trivial classification */\nconst TRIVIAL_MESSAGE_MAX_LENGTH = 80;\n\n/** Longer cap used when surface is Exec (one-shot prompts tend to be longer) */\nconst EXEC_TRIVIAL_MESSAGE_MAX_LENGTH = 200;\n\n/** Cap used for the sub-agent bias toward STANDARD */\nconst SUBAGENT_STANDARD_MESSAGE_MAX_LENGTH = 120;\n\n/** Minimum number of edits to be considered complex */\nconst COMPLEX_EDIT_THRESHOLD = 3;\n\n/**\n * Rule-based heuristic classifier used as a fallback when the Fireworks\n * classifier fails, times out, or returns an invalid response.\n *\n * Also used as the default classifier for the offline harness and\n * client-side experiments.\n *\n * Rules (evaluated in order):\n * 1. Complexity keywords → COMPLEX\n * 2. Many edits → COMPLEX\n * 3. Error recovery → COMPLEX\n * 4. Sub-agent with no edits, short message → STANDARD (sub-agents handle\n *    scoped work; avoid over-escalating)\n * 5. Exec surface with only read-only tools and short message → TRIVIAL\n * 6. Short message + only read-only tools → TRIVIAL\n * 7. Otherwise → STANDARD\n */\nexport function ruleBasedClassify(\n  signals: ClassifierSignals\n): TurnClassification {\n  const message = signals.lastUserMessage.toLowerCase();\n  const editCount = signals.recentToolCalls.filter((tc) =>\n    EDIT_TOOL_NAMES.has(tc.name)\n  ).length;\n  const hasErrors =\n    signals.hasFailedToolCalls ??\n    signals.recentToolCalls.some((tc) => tc.status === 'error');\n  const allToolsReadOnly =\n    signals.recentToolCalls.length === 0 ||\n    signals.recentToolCalls.every((tc) => READ_ONLY_TOOLS.has(tc.name));\n\n  if (COMPLEXITY_KEYWORDS.some((keyword) => message.includes(keyword))) {\n    return TurnClassification.COMPLEX;\n  }\n\n  if (editCount > COMPLEX_EDIT_THRESHOLD) {\n    return TurnClassification.COMPLEX;\n  }\n\n  if (hasErrors) {\n    return TurnClassification.COMPLEX;\n  }\n\n  if (\n    signals.isSubAgentSession &&\n    editCount === 0 &&\n    signals.lastUserMessage.length < SUBAGENT_STANDARD_MESSAGE_MAX_LENGTH\n  ) {\n    return TurnClassification.STANDARD;\n  }\n\n  if (\n    signals.surface === SessionSurface.Exec &&\n    allToolsReadOnly &&\n    signals.lastUserMessage.length < EXEC_TRIVIAL_MESSAGE_MAX_LENGTH\n  ) {\n    return TurnClassification.TRIVIAL;\n  }\n\n  if (\n    signals.lastUserMessage.length < TRIVIAL_MESSAGE_MAX_LENGTH &&\n    allToolsReadOnly\n  ) {\n    return TurnClassification.TRIVIAL;\n  }\n\n  return TurnClassification.STANDARD;\n}\n\n/**\n * Rule-based classifier implementing the TurnClassifier interface.\n * Always resolves synchronously — there is no network dependency.\n */\nexport class RuleBasedTurnClassifier implements TurnClassifier {\n  readonly name = 'rule-based';\n\n  async classify(signals: ClassifierSignals): Promise<ClassifierResult> {\n    const started = performance.now();\n    const classification = ruleBasedClassify(signals);\n    const latencyMs = performance.now() - started;\n    return {\n      classification,\n      confidence: RULE_BASED_CONFIDENCE,\n      latencyMs,\n      source: ClassifierSource.RuleBased,\n    };\n  }\n}\n",
