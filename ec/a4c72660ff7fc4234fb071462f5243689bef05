completions.create({\n        model: req.model,\n        messages: req.messages.map((m) => ({\n          role: m.role,\n          content: m.content,\n        })),\n        max_completion_tokens: req.maxCompletionTokens,\n        ...(req.responseFormat === 'json_object'\n          ? { response_format: { type: 'json_object' } }\n          : {}),\n        ...(req.reasoningEffort\n          ? { reasoning_effort: req.reasoningEffort }\n          : {}),\n        ...(req.temperature !== undefined\n          ? { temperature: req.temperature }\n          : {}),\n      });\n      const choice = completion.choices?.[0];\n      return {\n        content: choice?.message?.content ?? '',\n        usage: {\n          promptTokens: completion.usage?.prompt_tokens,\n          completionTokens: completion.usage?.completion_tokens,\n          cachedPromptTokens:\n            completion.usage?.prompt_tokens_details?.cached_tokens,\n        },\n      };\n    },\n  };\n}\n\n/**\n * Server-side model router. The CLI hits this endpoint when its dynamic\n * config sets `mode=server`. It instantiates a LocalRouter backed by the\n * GPT-5.4-mini scoring classifier and the cheapest-above-threshold\n * selector, so all clients share the exact same routing logic.\n */\nexport async function POST(request: NextRequest) {\n  return handleRouteMiddleware(\n    request,\n    async () => {\n      const parsed = BodySchema.safeParse(await parseJsonRequest(request));\n      if (!parsed.success) {\n        return NextResponse.json(\n          { error: 'Invalid request body', details: parsed.error.flatten() },\n          { status: 400 }\n        );\n      }\n\n      // Normalize to the exact ClassifierSignals shape — recentToolCalls has\n      // a default value in Zod but the droid-core type requires ReadonlyArray.\n      const signals = {\n        ...parsed.data.signals,\n        recentToolCalls: parsed.data.signals.recentToolCalls,\n      };\n\n      const classifier = new Gpt5MiniTaskClassifier({\n        client: buildOpenAIChatClient(),\n      });\n\n      const router = new LocalRouter({\n        classifier,\n        selector: defaultModelSelector,\n        candidates: DEFAULT_CANDIDATES,\n        decidedBy: RoutingDecisionSource.Server,\n      });\n\n      try {\n        const decision = await router.route(signals);\n        return NextResponse.json(decision);\n      } catch (error) {\n        // LocalRouter + Gpt5MiniTaskClassifier already fall back to the\n        // rule-based scorer on any per-call error, so we only land here\n        // on truly exceptional failures. Emit a safe Opus 4.6 decision so\n        // the CLI can still make progress.\n        logException(\n          error,\n          '[Router] select-model endpoint failed hard; emitting Opus fallback',\n          { sessionId: signals.sessionId }\n        );\n        return NextResponse.json(\n          {\n            options: buildFallbackOptions(\n              'Router endpoint hard failure; using Opus 4.6 fallback'\n            ),\n            classifierResult: {\n              scores: [],\n              latencyMs: 0,\n              source: 'rule-based' as const,\n            },\n            decidedAt: new Date().toISOString(),\n            decidedBy: RoutingDecisionSource.Server,\n            ttlMs: 60_000,\n            sessionId: signals.sessionId,\n          },\n          { status: 200 }\n        );\n      }\n    },\n    { rateLimit: RateLimitCategory.LLM_PROXY }\n  );\n}\n",
