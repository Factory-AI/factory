          "input": {
            "content": "/**\n * Offline routing evaluation harness for the Factory agent model router.\n *\n * Reads JSONL fixtures from a path (default: evals/router/fixtures.jsonl),\n * runs the configured classifier + selector against each entry, and\n * reports which primary model the router picked per case. Measures\n * per-fixture score distributions, selection accuracy against an\n * optional `expectedPrimary` label, and average classifier latency.\n *\n * Same code that runs in production via @factory/droid-core/model-router,\n * which is the entire point: any improvement we measure here applies\n * directly to the prod router.\n *\n * Usage:\n *   npm run router-eval -- --fixtures evals/router/fixtures.jsonl\n *   npm run router-eval -- --classifier rule-based\n *   npm run router-eval -- --classifier gpt5-mini --openai-api-key sk-...\n */\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport process from 'node:process';\n\nimport {\n  DEFAULT_CANDIDATES,\n  DefaultModelSelector,\n  Gpt5MiniTaskClassifier,\n  LocalRouter,\n  QUALITY_THRESHOLD,\n  RoutingDecisionSource,\n  RuleBasedTurnClassifier,\n  SessionSurface,\n  TurnClassification,\n} from '@factory/droid-core/model-router';\nimport { MetaError } from '@factory/logging/errors';\n\nimport type {\n  CandidateModel,\n  ClassifierSignals,\n  ModelRouter,\n  OpenAIChatCompletionClient,\n  OpenAIChatCompletionRequest,\n  OpenAIChatCompletionResponse,\n  RoutingDecision,\n  TurnClassifier,\n} from '@factory/droid-core/model-router';\nimport type { ModelID } from '@factory/common/llm';\n\ninterface FixtureEntry {\n  id: string;\n  /** Optional legacy bucket label, for backwards compat with older fixtures. */\n  expected?: TurnClassification;\n  /** Optional expected primary model id (preferred over `expected`). */\n  expectedPrimary?: ModelID;\n  signals: ClassifierSignals;\n}\n\ntype ClassifierMode = 'rule-based' | 'gpt5-mini';\n\ninterface CliArgs {\n  fixtures: string;\n  classifier: ClassifierMode;\n  openaiApiKey?: string;\n  jsonOutput: boolean;\n}\n\nfunction parseArgs(argv: string[]): CliArgs {\n  const args: CliArgs = {\n    fixtures: 'evals/router/fixtures.jsonl',\n    classifier: 'rule-based',\n    openaiApiKey: process.env.OPENAI_API_KEY,\n    jsonOutput: false,\n  };\n\n  for (let i = 0; i < argv.length; i += 1) {\n    const arg = argv[i];\n    if (arg === '--fixtures' && argv[i + 1]) {\n      args.fixtures = argv[i + 1]!;\n      i += 1;\n    } else if (arg === '--classifier' && argv[i + 1]) {\n      const value = argv[i + 1]!;\n      if (value !== 'rule-based' && value !== 'gpt5-mini') {\n        throw new MetaError(\n          \"--classifier must be 'rule-based' or 'gpt5-mini'\",\n          { value }\n        );\n      }\n      args.classifier = value;\n      i += 1;\n    } else if (arg === '--openai-api-key' && argv[i + 1]) {\n      args.openaiApiKey = argv[i + 1]!;\n      i += 1;\n    } else if (arg === '--json') {\n      args.jsonOutput = true;\n    }\n  }\n  return args;\n}\n\nfunction readFixtures(filePath: string): FixtureEntry[] {\n  if (!fs.existsSync(filePath)) {\n    throw new MetaError('Fixture file not found', { filePath });\n  }\n  const raw = fs.readFileSync(filePath, 'utf8');\n  return raw\n    .split('\\n')\n    .filter((line) => line.trim().length > 0)\n    .map((line, index) => {\n      try {\n        const obj = JSON.parse(line) as Partial<FixtureEntry>;\n        if (!obj.id || !obj.signals || !obj.signals.sessionId) {\n          throw new MetaError(\n            'Fixture missing one of required fields: id, signals.sessionId',\n            { line: index + 1 }\n          );\n        }\n        const signals: ClassifierSignals = {\n          ...obj.signals,\n          recentToolCalls: obj.signals.recentToolCalls ?? [],\n          surface: obj.signals.surface ?? SessionSurface.InteractiveTui,\n          isSubAgentSession: obj.signals.isSubAgentSession ?? false,\n          turnCount: obj.signals.turnCount ?? 0,\n          hasImages: obj.signals.hasImages ?? false,\n          lastUserMessage: obj.signals.lastUserMessage ?? '',\n        };\n        return {\n          id: obj.id,\n          expected: obj.expected,\n          expectedPrimary: obj.expectedPrimary,\n          signals,\n        };\n      } catch (error) {\n        throw new MetaError('Failed to parse fixture line', {\n          line: index + 1,\n          cause: (error as Error).message,\n        });\n      }\n    });\n}\n\n/**\n * Minimal OpenAI chat-completions client backed by the `openai` package,\n * configured to talk to the OpenAI API directly (no Factory proxy). Used\n * only in the offline eval harness.\n */\nasync function buildOpenAIClient(\n  apiKey: string\n): Promise<OpenAIChatCompletionClient> {\n  // Lazy-import so running the harness in rule-based mode never requires\n  // the `openai` package to even resolve.\n  // eslint-disable-next-line @typescript-eslint/no-require-imports\n  const mod = (await import('openai')) as typeof import('openai');\n  const client = new mod.OpenAI({ apiKey });\n  return {\n    complete: async (\n      req: OpenAIChatCompletionRequest\n    ): Promise<OpenAIChatCompletionResponse> => {\n      const completion = await client.chat.completions.create({\n        model: req.model,\n        messages: req.messages.map((m) => ({\n          role: m.role,\n          content: m.content,\n        })),\n        max_completion_tokens: req.maxCompletionTokens,\n        ...(req.responseFormat === 'json_object'\n          ? { response_format: { type: 'json_object' } }\n          : {}),\n        ...(req.reasoningEffort\n          ? { reasoning_effort: req.reasoningEffort }\n          : {}),\n        ...(req.temperature !== undefined\n          ? { temperature: req.temperature }\n          : {}),\n      });\n      const choice = completion.choices?.[0];\n      return {\n        content: choice?.message?.content ?? '',\n        usage: {\n          promptTokens: completion.usage?.prompt_tokens,\n         