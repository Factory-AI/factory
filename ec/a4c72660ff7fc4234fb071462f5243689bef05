            "new_str": "/**\n * Extract the concatenated text content (non-system-reminder) from a\n * conversation message. Returns the empty string for messages with\n * no text blocks at all. The session-reminder stripper is applied so\n * the classifier never sees AGENTS.md / todos / file-change tags.\n */\nfunction extractMessageText(message: FactoryDroidMessage): string {\n  if (!Array.isArray(message.content)) return '';\n  return message.content\n    .filter(\n      (b): b is Extract<typeof b, { type: 'text'; text: string }> =>\n        b.type === MessageContentBlockType.Text\n    )\n    .map((b) => b.text)\n    .join('\\n');\n}\n\n/** Remove every `<system-reminder>…</system-reminder>` block from `text`. */\nfunction stripSystemReminders(text: string): string {\n  return text\n    .replace(/<system-reminder>[\\s\\S]*?<\\/system-reminder>/g, '')\n    .trim();\n}\n\n/** Extract the inner text of every `<system-reminder>` block in `text`. */\nfunction extractSystemReminderBlocks(text: string): string[] {\n  const matches = Array.from(\n    text.matchAll(/<system-reminder>([\\s\\S]*?)<\\/system-reminder>/g)\n  );\n  return matches.map((m) => (m[1] ?? '').trim()).filter(Boolean);\n}\n\n/**\n * Extract ClassifierSignals from a Droid conversation history. Pulls\n * out rich session context (system info, first + current user turn,\n * a bounded recent-message window) plus recent tool calls and image\n * attachments so the classifier can make an informed decision.\n *\n * The `<session>` block we eventually send to the classifier is built\n * from these fields in `buildSessionContextXml`, so any new signal is\n * a matter of adding a field here + a branch in that renderer.\n */\nfunction buildClassifierSignalsFromHistory(args: {\n  conversationHistory: FactoryDroidMessage[];\n  surface: SessionSurface;\n  isSubAgent: boolean;\n  turnNumber: number;\n  sessionId: string;\n}): ClassifierSignals {\n  const { conversationHistory, surface, isSubAgent, turnNumber, session