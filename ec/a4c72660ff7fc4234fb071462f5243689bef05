            "content": "import { MAX_MESSAGE_LENGTH, MAX_RECENT_TOOL_CALLS } from '../constants';\n\nimport type { ClassifierSignals } from '../types';\n\n/**\n * Build the structured prompt for the Fireworks classifier.\n * Contains: last user message (truncated), recent tool calls, image presence,\n * turn count, surface (exec/interactive/sub-agent), and sub-agent flag.\n */\nexport function buildClassifierPrompt(signals: ClassifierSignals): string {\n  const truncatedMessage =\n    signals.lastUserMessage.length > MAX_MESSAGE_LENGTH\n      ? signals.lastUserMessage.slice(0, MAX_MESSAGE_LENGTH)\n      : signals.lastUserMessage;\n\n  const toolCallsSlice = signals.recentToolCalls.slice(-MAX_RECENT_TOOL_CALLS);\n  const toolCallsStr =\n    toolCallsSlice.length > 0\n      ? toolCallsSlice.map((tc) => `${tc.name}:${tc.status}`).join(', ')\n      : 'none';\n\n  const lines = [\n    `message: ${truncatedMessage}`,\n    `tools: ${toolCallsStr}`,\n    `images: ${signals.hasImages ? 'yes' : 'no'}`,\n    `turn: ${signals.turnCount}`,\n    `surface: ${signals.surface}`,\n    `sub_agent: ${signals.isSubAgentSession ? 'yes' : 'no'}`,\n  ];\n\n  if (signals.conversationSummary) {\n    lines.push(`summary: ${signals.conversationSummary.slice(0, 240)}`);\n  }\n\n  return lines.join('\\n');\n}\n",
