            "content": "import { MetaError } from '@factory/logging/errors';\n\nimport {\n  DEFAULT_DECISION_TTL_MS,\n  DEFAULT_ROUTER_ENDPOINT,\n} from '../constants';\nimport {\n  ClassifierSource,\n  RoutingDecisionSource,\n  TurnClassification,\n} from '../enums';\nimport { buildFallbackOptions } from '../selector';\n\nimport type {\n  ClassifierSignals,\n  ModelRouter,\n  RemoteApiRouterDeps,\n  RouterFetcher,\n  RouterRequestBody,\n  RoutingDecision,\n} from '../types';\n\n/**\n * A router that delegates decisions to the backend endpoint\n * `/api/llm/router/select-model`. Used in prod to keep classification and\n * model selection server-side.\n */\nexport class RemoteApiRouter implements ModelRouter {\n  readonly name = 'remote-api';\n\n  private readonly fetcher: RouterFetcher;\n\n  private readonly endpoint: string;\n\n  private readonly fallbackOnError: boolean;\n\n  private readonly now: () => Date;\n\n  constructor(deps: RemoteApiRouterDeps) {\n    this.fetcher = deps.fetcher;\n    this.endpoint = deps.endpoint ?? DEFAULT_ROUTER_ENDPOINT;\n    this.fallbackOnError = deps.fallbackOnError ?? true;\n    this.now = deps.now ?? (() => new Date());\n  }\n\n  async route(signals: ClassifierSignals): Promise<RoutingDecision> {\n    try {\n      const body: RouterRequestBody = { signals };\n      const response = await this.fetcher(this.endpoint, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify(body),\n      });\n      if (!response.ok) {\n        throw new MetaError('Router API returned non-OK status', {\n          statusCode: String(response.status),\n        });\n      }\n      const decision = (await response.json()) as RoutingDecision;\n      return {\n        ...decision,\n        decidedBy: RoutingDecisionSource.Server,\n      };\n    } catch (error) {\n      if (!this.fallbackOnError) throw error;\n      return this.buildFallbackDecision(signals);\n    }\n  }\n\n  private buildFallbackDecision(signals: ClassifierSignals): RoutingDecision {\n    return {\n      options: buildFallbackOptions(\n        'Remote router unavailable; using Opus 4.6 fallback'\n      ),\n      classification: TurnClassification.COMPLEX,\n      classifierResult: {\n        classification: TurnClassification.COMPLEX,\n        confidence: 0,\n        latencyMs: 0,\n        source: ClassifierSource.RemoteApi,\n      },\n      decidedAt: this.now().toISOString(),\n      decidedBy: RoutingDecisionSource.Client,\n      ttlMs: DEFAULT_DECISION_TTL_MS,\n      sessionId: signals.sessionId,\n    };\n  }\n}\n",
