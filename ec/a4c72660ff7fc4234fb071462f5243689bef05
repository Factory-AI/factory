            "content": "import { ApiProvider, ReasoningEffort } from '@factory/common/llm';\nimport { ROUTER_FALLBACK_MODEL } from '@factory/utils/llm';\n\nimport { QUALITY_THRESHOLD } from './constants';\n\nimport type {\n  CandidateModel,\n  CandidateScore,\n  ClassifierResult,\n  ClassifierSignals,\n  ModelOption,\n  ModelSelector,\n} from './types';\n\ninterface ScoredCandidate {\n  candidate: CandidateModel;\n  score: number;\n}\n\n/**\n * Join per-candidate scores against the candidate catalog. Drops any\n * scores that reference a modelId not in the catalog (defense-in-depth\n * against stale scoring payloads).\n */\nfunction joinScores(\n  candidates: readonly CandidateModel[],\n  scores: readonly CandidateScore[]\n): ScoredCandidate[] {\n  const byId = new Map(scores.map((s) => [s.modelId, s.score] as const));\n  return candidates.map((candidate) => ({\n    candidate,\n    score: byId.get(candidate.modelId) ?? 0,\n  }));\n}\n\n/**\n * Core selection rule:\n *\n *  1. Split into viable (score ≥ QUALITY_THRESHOLD) and the rest.\n *  2. If any viable candidates exist → pick the one with the lowest\n *     input cost. Cost ties broken by score (higher wins), then by\n *     order in the candidate list.\n *  3. If nothing meets the threshold → pick the candidate with the\n *     highest score (falling back to list order for ties).\n *  4. Remaining candidates become ordered fallbacks (best-score first).\n */\nfunction selectPrimary(\n  scored: readonly ScoredCandidate[]\n): { primary: ScoredCandidate; fallbacks: ScoredCandidate[] } | null {\n  if (scored.length === 0) return null;\n\n  const viable = scored.filter((s) => s.score >= QUALITY_THRESHOLD);\n  if (viable.length > 0) {\n    const sortedByCost = [...viable].sort((a, b) => {\n      const costDiff = a.candidate.inputCostPer1M - b.candidate.inputCostPer1M;\n      if (costDiff !== 0) return costDiff;\n      return b.score - a.score;\n    });\n    const [primary, ...rest] = sortedByCost;\n    // Non-viable c