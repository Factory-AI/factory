;\n  /** Per-candidate description override. Keys are model IDs. */\n  candidateDescriptions?: Record<string, string>;\n}\n\n// ---------- Fixture loading ----------\n\nfunction readFixtures(filePath: string): FixtureEntry[] {\n  const raw = fs.readFileSync(filePath, 'utf8');\n  return raw\n    .split('\\n')\n    .filter((l) => l.trim().length > 0)\n    .map((line, index) => {\n      const obj = JSON.parse(line) as Partial<FixtureEntry>;\n      if (!obj.id || !obj.signals?.sessionId) {\n        throw new MetaError('Bad fixture line', {\n          filePath,\n          value: `line ${index + 1}`,\n        });\n      }\n      const signals: ClassifierSignals = {\n        ...obj.signals,\n        recentToolCalls: obj.signals.recentToolCalls ?? [],\n        surface: obj.signals.surface ?? SessionSurface.InteractiveTui,\n        isSubAgentSession: obj.signals.isSubAgentSession ?? false,\n        turnCount: obj.signals.turnCount ?? 0,\n        hasImages: obj.signals.hasImages ?? false,\n        currentUserMessage: obj.signals.currentUserMessage ?? '',\n      };\n      return {\n        id: obj.id,\n        expectedPrimary: obj.expectedPrimary,\n        signals,\n      };\n    });\n}\n\n// ---------- OpenAI client ----------\n\nfunction toOpenAIResponseFormat(\n  responseFormat: OpenAIChatCompletionRequest['responseFormat']\n) {\n  if (!responseFormat) return undefined;\n  if (responseFormat.type === 'json_object') {\n    return { type: 'json_object' as const };\n  }\n  return {\n    type: 'json_schema' as const,\n    json_schema: {\n      name: responseFormat.jsonSchema.name,\n      strict: responseFormat.jsonSchema.strict,\n      schema: responseFormat.jsonSchema.schema,\n    },\n  };\n}\n\nasync function buildOpenAIClient(\n  apiKey: string\n): Promise<OpenAIChatCompletionClient> {\n  const mod = (await import('openai')) as typeof import('openai');\n  const client = new mod.OpenAI({ apiKey });\n  return {\n    complete: async (req) => {\n      const responseFormat = toOpenAIResponseFormat(req.responseFormat);\n      const completion = await client.chat.completions.create({\n        model: req.model,\n        messages: req.messages.map((m) => ({\n          role: m.role,\n          content: m.content,\n        })),\n        max_completion_tokens: req.maxCompletionTokens,\n        ...(responseFormat ? { response_format: responseFormat } : {}),\n        ...(req.reasoningEffort\n          ? { reasoning_effort: req.reasoningEffort }\n          : {}),\n      });\n      const choice = completion.choices?.[0];\n      return {\n        content: choice?.message?.content ?? '',\n        usage: {\n          promptTokens: completion.usage?.prompt_tokens,\n          completionTokens: completion.usage?.completion_tokens,\n          cachedPromptTokens:\n            completion.usage?.prompt_tokens_details?.cached_tokens,\n        },\n      };\n    },\n  };\n}\n\n// ---------- Variant-aware classifier + selector ----------\n\ninterface VariantClassifierDeps {\n  client: OpenAIChatCompletionClient;\n  variant: VariantConfig;\n}\n\nfunction applyVariantToCandidates(\n  variant: VariantConfig,\n  candidates: readonly CandidateModel[]\n): CandidateModel[] {\n  if (!variant.candidateDescriptions) return [...candidates];\n  return candidates.map((c) =>\n    variant.candidateDescriptions![c.modelId]\n      ? { ...c, shortDescription: variant.candidateDescriptions![c.modelId]! }\n      : c\n  );\n}\n\nfunction buildSystemPrompt(\n  variant: VariantConfig,\n  candidates: readonly CandidateModel[]\n): string {\n  if (variant.systemPromptOverride) {\n    return variant.systemPromptOverride(candidates);\n  }\n  // Inline copy of buildStaticClassifierSystemPrompt with the new\n  // QUALITY_THRESHOLD substituted in. Keeping it inline avoids the\n  // need to expose threshold parameterization in droid-core itself.\n  const candidateBlocks = candidates\n    .map((candidate, index) => {\n      const imageTag = candidate.supportsImages\n        ? 'handles images'\n   