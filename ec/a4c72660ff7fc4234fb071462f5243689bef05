            "content": "/** Default TTL for a routing decision (ms) — 1 minute. */\nexport const DEFAULT_DECISION_TTL_MS = 60_000;\n\n/** Default endpoint path for the backend router API. */\nexport const DEFAULT_ROUTER_ENDPOINT = '/api/llm/router/select-model';\n\n/**\n * Minimum score a candidate must reach to be considered \"good enough\"\n * for the selection phase. See `selector.ts` for the full policy.\n */\nexport const QUALITY_THRESHOLD = 0.7;\n\n/**\n * Maximum total input tokens sent to the GPT-5.4-mini classifier, covering\n * both the cached static prefix and the dynamic task suffix. 16k tokens is\n * roughly ~$0.0015 per classification at GPT-5.4-mini rates and leaves\n * headroom for the rolling conversation summary when it exists.\n */\nexport const MAX_CLASSIFIER_INPUT_TOKENS = 16_000;\n\n/**\n * Target static-prefix size in approximate tokens. OpenAI's automatic\n * prompt cache aligns on 1_024-token boundaries (first block) then grows\n * in 128-token increments, so we want a stable multiple-of-128 prefix.\n * 2_048 tokens comfortably holds two model cards + scoring rubric and\n * produces a full-block cache hit on the 1024-byte boundary.\n */\nexport const STATIC_PREFIX_TARGET_TOKENS = 2_048;\n\n/**\n * Upper bound on tokens allocated to the dynamic task suffix (user\n * message + tool history + conversation summary). Any overflow is\n * truncated in order of priority: summary → tool history → message.\n */\nexport const DYNAMIC_SUFFIX_MAX_TOKENS =\n  MAX_CLASSIFIER_INPUT_TOKENS - STATIC_PREFIX_TARGET_TOKENS;\n\n/** Default classifier model id. Matches ModelID.GPT_5_4_MINI. */\nexport const GPT5_MINI_CLASSIFIER_MODEL_ID = 'gpt-5.4-mini';\n\n/**\n * `max_completion_tokens` for the classifier. We need ~20 tokens per\n * candidate for the JSON score blob plus a short reasoning string — 400\n * tokens is generous and still cheap.\n */\nexport const CLASSIFIER_MAX_COMPLETION_TOKENS = 400;\n\n/** Maximum character length for the user message in the classifier prompt */\nexport const MAX_MESSAGE_LENGTH = 4_000;\n\n/** Maximum number of recent tool calls to include in the classifier prompt */\nexport const MAX_RECENT_TOOL_CALLS = 8;\n\n/**\n * Conservative character → token estimate used for truncation budgets.\n * Actual ratios vary by content, but 4 chars/token is a safe upper bound\n * for English prose + code snippets, and the GPT-5.4-mini tokenizer's\n * byte-pair encoding rarely exceeds it.\n */\nexport const CHARS_PER_TOKEN_ESTIMATE = 4;\n",
