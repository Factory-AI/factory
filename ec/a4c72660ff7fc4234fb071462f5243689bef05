ierResult.source).toBe(ClassifierSource.Gpt5Mini);\n    expect(decision.decidedBy).toBe(RoutingDecisionSource.Client);\n  });\n\n  it('passes candidate list and signals through to the classifier', async () => {\n    let capturedSignals: ClassifierSignals | undefined;\n    let capturedCandidates: readonly CandidateModel[] | undefined;\n    const classifier: TurnClassifier = {\n      name: 'capture',\n      classify: async (sig, candidates) => {\n        capturedSignals = sig;\n        capturedCandidates = candidates;\n        return {\n          scores: candidates.map((c) => ({ modelId: c.modelId, score: 0.9 })),\n          latencyMs: 0,\n          source: ClassifierSource.Gpt5Mini,\n        };\n      },\n    };\n    const router = new Router({\n      classifier,\n      selector: defaultModelSelector,\n      candidates: DEFAULT_CANDIDATES,\n    });\n\n    await router.route(signals({ currentUserMessage: 'x' }));\n\n    expect(capturedSignals?.currentUserMessage).toBe('x');\n    expect(capturedCandidates).toBe(DEFAULT_CANDIDATES);\n  });\n\n  it('emits a safe Opus fallback decision when the classifier throws', async () => {\n    const router = new Router({\n      classifier: throwingClassifier(new Error('upstream 500')),\n      selector: defaultModelSelector,\n      candidates: DEFAULT_CANDIDATES,\n    });\n\n    const decision = await router.route(signals());\n\n    expect(decision.options).toHaveLength(1);\n    expect(decision.options[0]?.modelId).toBe(ModelID.CLAUDE_OPUS_4_6);\n    expect(decision.options[0]?.apiProvider).toBe(ApiProvider.ANTHROPIC);\n    expect(decision.options[0]?.reasoningEffort).toBe(ReasoningEffort.High);\n    expect(decision.classification).toBe(TurnClassification.COMPLEX);\n    expect(decision.classifierResult.source).toBe(ClassifierSource.Fallback);\n  });\n\n  it('emits a safe fallback when the selector returns nothing viable', async () => {\n    // All candidates hard-rejected via explicit zero scores.\n    const classifier = staticClassifier({\n      scores: [\n        { modelId: ModelID.MINIMAX_M2_5, score: 0 },\n        { modelId: ModelID.CLAUDE_OPUS_4_6, score: 0 },\n      ],\n      latencyMs: 0,\n      source: ClassifierSource.Gpt5Mini,\n    });\n    const router = new Router({\n      classifier,\n      selector: defaultModelSelector,\n      candidates: DEFAULT_CANDIDATES,\n    });\n\n    const decision = await router.route(signals({ hasImages: true }));\n\n    // Selector emits the in-built Opus fallback option itself; the\n    // Router passes that through unchanged.\n    expect(decision.options[0]?.modelId).toBe(ModelID.CLAUDE_OPUS_4_6);\n  });\n\n  it('uses the injected clock for decidedAt', async () => {\n    const fixed = new Date('2026-04-09T12:00:00.000Z');\n    const classifier = staticClassifier({\n      scores: [{ modelId: ModelID.MINIMAX_M2_5, score: 0.9 }],\n      latencyMs: 0,\n      source: ClassifierSource.Gpt5Mini,\n    });\n    const router = new Router({\n      classifier,\n      selector: defaultModelSelector,\n      candidates: DEFAULT_CANDIDATES,\n      now: () => fixed,\n    });\n\n    const decision = await router.route(signals());\n    expect(decision.decidedAt).toBe(fixed.toISOString());\n  });\n\n  it('honors the ttlMs override', async () => {\n    const classifier = staticClassifier({\n      scores: [{ modelId: ModelID.MINIMAX_M2_5, score: 0.9 }],\n      latencyMs: 0,\n      source: ClassifierSource.Gpt5Mini,\n    });\n    const router = new Router({\n      classifier,\n      selector: defaultModelSelector,\n      candidates: DEFAULT_CANDIDATES,\n      ttlMs: 5_000,\n    });\n\n    const decision = await router.route(signals());\n    expect(decision.ttlMs).toBe(5_000);\n  });\n});\n",
