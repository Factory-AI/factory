            "content": "import { ApiProvider, ModelID, ReasoningEffort } from '@factory/common/llm';\nimport {\n  ROUTER_COMPLEX_MODEL,\n  ROUTER_FALLBACK_MODEL,\n  ROUTER_IMAGE_FALLBACK_MODEL,\n  ROUTER_STANDARD_MODEL,\n  ROUTER_TRIVIAL_MODEL,\n} from '@factory/utils/llm';\n\nimport { TurnClassification } from './enums';\n\nimport type {\n  ClassifierResult,\n  ClassifierSignals,\n  ModelOption,\n  ModelSelector,\n} from './types';\n\ninterface ClassificationMapping {\n  modelId: ModelID;\n  apiProvider: ApiProvider;\n  reasoningEffort: ReasoningEffort;\n}\n\n/**\n * Default mapping of classification → primary model option.\n * Swapping this map is how we adjust the router's cost/quality tradeoff.\n */\nconst DEFAULT_CLASSIFICATION_MAP: Record<\n  TurnClassification,\n  ClassificationMapping\n> = {\n  [TurnClassification.TRIVIAL]: {\n    modelId: ROUTER_TRIVIAL_MODEL,\n    apiProvider: ApiProvider.FIREWORKS,\n    reasoningEffort: ReasoningEffort.Low,\n  },\n  [TurnClassification.STANDARD]: {\n    modelId: ROUTER_STANDARD_MODEL,\n    apiProvider: ApiProvider.FIREWORKS,\n    reasoningEffort: ReasoningEffort.Medium,\n  },\n  [TurnClassification.COMPLEX]: {\n    modelId: ROUTER_COMPLEX_MODEL,\n    apiProvider: ApiProvider.ANTHROPIC,\n    reasoningEffort: ReasoningEffort.High,\n  },\n};\n\n/**\n * Build an ordered list of model options for a given classification.\n * The primary choice is followed by a COMPLEX-tier fallback so\n * clients can retry with a stronger model on upstream errors.\n */\nfunction buildOptionsFromClassification(\n  classification: TurnClassification,\n  signals: ClassifierSignals\n): ModelOption[] {\n  // Images force Opus 4.6 as the primary — MiniMax can't handle images.\n  if (signals.hasImages) {\n    return [\n      {\n        modelId: ROUTER_IMAGE_FALLBACK_MODEL,\n        apiProvider: ApiProvider.ANTHROPIC,\n        reasoningEffort: ReasoningEffort.High,\n        rank: 0,\n        rationale:\n          'Images detected; routing to Opus 4.6 (MiniMax cannot process images)',\n      },\n    ];\n  }\n\n  const primary = DEFAULT_CLASSIFICATION_MAP[classification];\n  const options: ModelOption[] = [\n    {\n      modelId: primary.modelId,\n      apiProvider: primary.apiProvider,\n      reasoningEffort: primary.reasoningEffort,\n      rank: 0,\n      rationale: `Classified as ${classification}; primary = ${primary.modelId}`,\n    },\n  ];\n\n  // Always offer Opus 4.6 as a fallback for non-COMPLEX classifications so\n  // the agent can retry with a stronger model on upstream errors.\n  if (classification !== TurnClassification.COMPLEX) {\n    options.push({\n      modelId: ROUTER_FALLBACK_MODEL,\n      apiProvider: ApiProvider.ANTHROPIC,\n      reasoningEffort: ReasoningEffort.High,\n      rank: 1,\n      rationale: 'Fallback to Opus 4.6 for retry on upstream errors',\n    });\n  }\n\n  return options;\n}\n\n/**\n * The default model selector used by both client and server routers.\n * Takes a classifier result + signals and returns an ordered list of\n * concrete model options (primary first).\n */\nexport class DefaultModelSelector implements ModelSelector {\n  readonly name = 'default';\n\n  select(result: ClassifierResult, signals: ClassifierSignals): ModelOption[] {\n    return buildOptionsFromClassification(result.classification, signals);\n  }\n}\n\n/** Shared singleton of the default selector. */\nexport const defaultModelSelector = new DefaultModelSelector();\n\n/**\n * Build a single-option fallback decision list (Opus 4.6) for cases where\n * routing is disabled or classification fails.\n */\nexport function buildFallbackOptions(reason: string): ModelOption[] {\n  return [\n    {\n      modelId: ROUTER_FALLBACK_MODEL,\n      apiProvider: ApiProvider.ANTHROPIC,\n      reasoningEffort: ReasoningEffort.High,\n      rank: 0,\n      rationale: reason,\n    },\n  ];\n}\n",
