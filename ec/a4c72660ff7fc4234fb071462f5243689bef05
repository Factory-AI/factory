            "content": "import { ApiProvider, ModelID, ReasoningEffort } from '@factory/common/llm';\n\nimport type { CandidateModel } from './types';\n\n/**\n * Default two-model candidate list shipped with the router: Opus 4.6 for\n * complex work, MiniMax M2.5 for the long tail of standard coding. These\n * descriptions are intentionally compact — they ride in the cached static\n * prefix of the classifier prompt, so every extra token adds latency and\n * cost on every routed turn.\n *\n * Costs are expressed relative to each model's pricing (USD per 1M\n * tokens). The selector only uses them for ordering, so the exact\n * numbers can drift without changing behavior as long as the relative\n * ranking stays correct.\n */\nexport const DEFAULT_CANDIDATE_OPUS_4_6: CandidateModel = {\n  modelId: ModelID.CLAUDE_OPUS_4_6,\n  apiProvider: ApiProvider.ANTHROPIC,\n  reasoningEffort: ReasoningEffort.High,\n  inputCostPer1M: 15,\n  outputCostPer1M: 75,\n  supportsImages: true,\n  shortDescription:\n    'Claude Opus 4.6 (Anthropic): best-in-class for multi-file refactors, deep debugging, and architecture decisions. Handles ambiguous requirements and long reasoning chains gracefully. Accepts images. Slower and ~50x more expensive than MiniMax; overkill for simple edits.',\n};\n\nexport const DEFAULT_CANDIDATE_MINIMAX_M2_5: CandidateModel = {\n  modelId: ModelID.MINIMAX_M2_5,\n  apiProvider: ApiProvider.FIREWORKS,\n  reasoningEffort: ReasoningEffort.High,\n  inputCostPer1M: 0.3,\n  outputCostPer1M: 1.2,\n  supportsImages: false,\n  shortDescription:\n    'MiniMax M2.5 (Fireworks): fast, cheap, strong tool-calling model tuned for standard coding loops — single-file edits, grep/read/test runs, checklist execution, short Q&A. Struggles on multi-file refactors, subtle debugging, and long reasoning chains. Cannot see images. ~50x cheaper than Opus 4.6.',\n};\n\n/** Default candidate list used when no dynamic config override is present. */\nexport const DEFAULT_CANDIDATES: readonly CandidateModel[] = [\n  DEFAULT_CANDIDATE_OPUS_4_6,\n  DEFAULT_CANDIDATE_MINIMAX_M2_5,\n];\n",
