            "content": "import { SessionSurface } from './enums';\n\n/**\n * Context passed to a RoutingPolicy at every turn. The agent populates\n * this at call time from SessionService state; policies themselves must\n * be pure functions of the context so they can be swapped easily.\n */\nexport interface RoutingPolicyContext {\n  surface: SessionSurface;\n  isSubAgent: boolean;\n  /** 0-indexed assistant turn number within the session */\n  turnNumber: number;\n  /** Whether an effective model is already cached on the session */\n  hasEffectiveModel: boolean;\n  /** Milliseconds since the current effective model was chosen (Infinity if none) */\n  effectiveModelAge: number;\n}\n\n/**\n * Decides whether *this turn* should consult the model router.\n */\nexport interface RoutingPolicy {\n  readonly name: string;\n  shouldRoute(ctx: RoutingPolicyContext): boolean;\n}\n\n// ============ Primitives ============\n\n/** Always route, on every turn. */\nexport const everyTurn: RoutingPolicy = {\n  name: 'every-turn',\n  shouldRoute: () => true,\n};\n\n/** Route only on the Nth assistant turn (0-indexed). */\nexport function onceAtTurn(turn: number): RoutingPolicy {\n  return {\n    name: `once-at-turn-${turn}`,\n    shouldRoute: (ctx) => ctx.turnNumber === turn,\n  };\n}\n\n/**\n * Route only if no effective model has been chosen yet.\n * This is the cheapest policy — one router call per session.\n */\nexport const onlyOnFirstCall: RoutingPolicy = {\n  name: 'once-per-session',\n  shouldRoute: (ctx) => !ctx.hasEffectiveModel,\n};\n\n/** Route only when the session surface matches. */\nexport function onlyForSurface(surface: SessionSurface): RoutingPolicy {\n  return {\n    name: `surface-${surface}`,\n    shouldRoute: (ctx) => ctx.surface === surface,\n  };\n}\n\n/** Route only for sub-agent sessions (Task tool workers). */\nexport const onlyForSubAgents: RoutingPolicy = {\n  name: 'sub-agents-only',\n  shouldRoute: (ctx) => ctx.isSubAgent,\n};\n\n/**\n * Route again once the current effective model is older than the threshold.\n * Useful as an OR leg alongside onlyOnFirstCall to re-evaluate stale decisions.\n */\nexport function expireAfter(ms: number): RoutingPolicy {\n  return {\n    name: `expire-${ms}ms`,\n    shouldRoute: (ctx) => ctx.effectiveModelAge > ms,\n  };\n}\n\n/** Never route — useful as a kill switch for specific surfaces. */\nexport const neverRoute: RoutingPolicy = {\n  name: 'never',\n  shouldRoute: () => false,\n};\n\n// ============ Combinators ============\n\nexport function and(...policies: RoutingPolicy[]): RoutingPolicy {\n  return {\n    name: `and(${policies.map((p) => p.name).join(',')})`,\n    shouldRoute: (ctx) => policies.every((p) => p.shouldRoute(ctx)),\n  };\n}\n\nexport function or(...policies: RoutingPolicy[]): RoutingPolicy {\n  return {\n    name: `or(${policies.map((p) => p.name).join(',')})`,\n    shouldRoute: (ctx) => policies.some((p) => p.shouldRoute(ctx)),\n  };\n}\n\nexport function not(policy: RoutingPolicy): RoutingPolicy {\n  return {\n    name: `not(${policy.name})`,\n    shouldRoute: (ctx) => !policy.shouldRoute(ctx),\n  };\n}\n",
