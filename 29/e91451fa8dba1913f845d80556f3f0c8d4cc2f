TEN_MODE_VALUES)\n        .default(DaemonListenMode.WebSocket)\n    )\n    .addOption(new Option('--enable-child-ipc', 'Enable IPC'))\n    .addOption(new Option('--droid-path <path>', 'Path to droid executable'))\n    .addOption(new Option('--liveness-fd <fd>', 'Monitor parent via pipe'))\n    .addOption(new Option('--parent-pid <pid>', 'Monitor parent process'))\n    .addOption(new Option('--remote-access', 'Allow remote access'))\n    .allowUnknownOption(true)\n    .helpOption(false)\n    .action(async () => { await import('./run.js'); });\n}\n```\n\n---\n\n## Phase 3: Rewrite `index.ts` as thin declarative dispatcher\n\n```ts\nimport { Command, Option } from 'commander';\n\n// Lightweight factory imports (no heavy deps вҖ” only commander + constants)\nimport { makeCommand as makeDaemonCmd } from '@/entrypoints/daemon/command';\nimport { makeCommand as makeSearchCmd } from '@/entrypoints/search/command';\nimport { makeCommand as makeUpdateCmd } from '@/entrypoints/update/command';\nimport { makeCommand as makeMcpCmd } from '@/entrypoints/mcp/command';\nimport { makeCommand as makePluginCmd } from '@/entrypoints/plugin/command';\nimport { makeCommand as makeComputerCmd } from '@/entrypoints/computer/command';\nimport { makeCommand as makeExecCmd } from '@/entrypoints/exec/command';\n// ... hidden commands\n\nconst program = new Command();\nprogram\n  .name('droid')\n  .description(\"Droid - Factory's AI coding agent in your terminal\")\n  .version(process.env.CLI_VERSION || 'unknown', '-v, --version')\n  .enablePositionalOptions()\n  // Global TUI options (needed for correct argv routing)\n  .addOption(new Option('--settings <path>', 'Runtime settings file'))\n  .addOption(new Option('-r, --resume [sessionId]', 'Resume a session'))\n  .addOption(new Option('--fork <sessionId>', 'Fork and resume'))\n  .addOption(new Option('--cwd <path>', 'Working directory'))\n  .addOption(new Option('-w, --worktree [name]', 'Run in git worktree'))\n  .addOption(new Option('--worktree-dir <path>', 'Worktree directory'))\n  .addOption(new Option('--append-system-prompt <text>', 'Append to system prompt'))\n  .addOption(new Option('--append-system-prompt-file <path>', 'Append file to system prompt'))\n  .helpOption('-h, --help');\n\n// Visible commands (use v14 help groups)\nprogram\n  .addCommand(makeDaemonCmd())\n  .addCommand(makeSearchCmd())\n  .addCommand(makeUpdateCmd())\n  .addCommand(makeMcpCmd())\n  .addCommand(makePluginCmd())\n  .addCommand(makeComputerCmd());\n\n// Hidden commands\nprogram.addCommand(makeExecCmd());\n// ... wiki-read, wiki-search, etc.\n\n// Default: TUI (allowExcessArguments for free-form prompt)\nprogram\n  .allowUnknownOption(true)\n  .allowExcessArguments(true)\n  .arguments('[prompt...]')\n  .action(async () => { await import('@/entrypoints/tui/run.js'); });\n\nprogram.exitOverride();\nawait program.parseAsync(process.argv);\n```\n\nDelete old `entrypoints/subcommands.ts` once all commands have their own entrypoint.\n\n---\n\n## `commands/` folder вҖ” untouched\n\nAll existing `commands/*.ts` files stay in place. The entrypoint `run.ts` files import from them (`createSearchCommand()`, `createDaemonCommand()`, etc.).\n\n---\n\n## Execution order\n\n1. **Upgrade commander** to `^14.0.3`, fix breaking changes (allowExcessArguments, etc.)\n2. **Phase 1** вҖ” create `entrypoints/bootstrap/` shared layers\n3. **Phase 2** вҖ” create per-command `command.ts` + `run.ts` folders\n4. **Phase 3** вҖ” rewrite `index.ts` using `addCommand()` pattern, delete `subcommands.ts`\n\nEach step is independently shippable as a PR.",
