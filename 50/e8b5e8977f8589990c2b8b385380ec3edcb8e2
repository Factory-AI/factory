            "content": "/**\n * @jest-environment node\n */\n\n/**\n * Integration tests for the liveness pipe mechanism used by DaemonCore.\n *\n * Verifies that a child process monitoring a liveness fd exits when the\n * parent-held pipe is closed. Uses real processes -- no mocks.\n *\n * The liveness-child.ts helper mirrors what DaemonCore.startLivenessMonitor()\n * does: open a net.Socket on an inherited fd, exit when it closes.\n *\n * Architecture:\n *   Jest (this file) acts as the \"parent\"\n *     └── liveness-child.ts (the \"daemon\") with fd 3 = liveness pipe\n */\nimport { ChildProcess, spawn } from 'child_process';\nimport path from 'path';\n\nconst TSX_BIN = path.resolve(\n  __dirname,\n  '..', // src\n  '..', // daemon-core\n  '..', // packages\n  '..', // factory-mono\n  'node_modules',\n  '.bin',\n  'tsx'\n);\n\nconst CHILD_SCRIPT = path.resolve(__dirname, 'helpers', 'liveness-child.ts');\n\nfunction spawnChild(): {\n  child: ChildProcess;\n  waitForReady: () => Promise<void>;\n} {\n  const child = spawn(TSX_BIN, [CHILD_SCRIPT, '3'], {\n    stdio: ['ignore', 'pipe', 'inherit', 'pipe'], // fd 3 = liveness pipe\n  });\n\n  const waitForReady = () =>\n    new Promise<void>((resolve, reject) => {\n      const timeout = setTimeout(\n        () => reject(new Error('Child did not become ready within 10s')),\n        10000\n      );\n      let buffer = '';\n      child.stdout!.on('data', (data: Buffer) => {\n        buffer += data.toString();\n        if (buffer.includes('READY')) {\n          clearTimeout(timeout);\n          resolve();\n        }\n      });\n      child.on('error', (err) => {\n        clearTimeout(timeout);\n        reject(err);\n      });\n      child.on('exit', (code) => {\n        clearTimeout(timeout);\n        if (!buffer.includes('READY')) {\n          reject(new Error(`Child exited before ready with code ${code}`));\n        }\n      });\n    });\n\n  return { child, waitForReady };\n}\n\nfunction waitForExit(\n  child: ChildProcess,\n  timeoutMs = 10000\n): Promise<number | null> {\n  return new Promise((resolve, reject) => {\n    if (child.exitCode !== null) {\n      resolve(child.exitCode);\n      return;\n    }\n    const timeout = setTimeout(() => {\n      child.kill('SIGKILL');\n      reject(new Error(`Child did not exit within ${timeoutMs}ms`));\n    }, timeoutMs);\n\n    child.on('exit', (code) => {\n      clearTimeout(timeout);\n      resolve(code);\n    });\n  });\n}\n\nfunction isProcessAlive(pid: number): boolean {\n  try {\n    process.kill(pid, 0);\n    return true;\n  } catch {\n    return false;\n  }\n}\n\ndescribe('liveness-fd integration', () => {\n  let child: ChildProcess | null = null;\n\n  afterEach(() => {\n    if (child && child.exitCode === null) {\n      child.kill('SIGKILL');\n    }\n    child = null;\n  });\n\n  it('child exits when parent closes the liveness pipe', async () => {\n    const spawned = spawnChild();\n    child = spawned.child;\n\n    await spawned.waitForReady();\n    expect(isProcessAlive(child.pid!)).toBe(true);\n\n    // Close the liveness pipe (fd 3) -- simulates parent death\n    const livenessPipe = child.stdio[3] as NodeJS.WritableStream;\n    livenessPipe.destroy();\n\n    const exitCode = await waitForExit(child);\n    expect(exitCode).toBe(0);\n  });\n\n  it('child exits when all parent stdio is destroyed (crash simulation)', async () => {\n    const spawned = spawnChild();\n    child = spawned.child;\n\n    await spawned.waitForReady();\n    expect(isProcessAlive(child.pid!)).toBe(true);\n\n    // Destroy all stdio to simulate abrupt parent death\n    for (const stream of child.stdio) {\n      if (stream && 'destroy' in stream) {\n        (stream as NodeJS.WritableStream).destroy();\n      }\n    }\n\n    const exitCode = await waitForExit(child);\n    expect(exitCode).toBe(0);\n  });\n\n  it('child stays alive while parent holds the pipe open', async () => {\n    const spawned = spawnChild();\n    child = spawned.child;\n\n    await spawned.waitForReady();\n\n    // Wait a bit and confirm child is still running\n    await new Promise((r) => setTimeout(r, 2000));\n    expect(isProcessAlive(child.pid!)).toBe(true);\n    expect(child.exitCode).toBeNull();\n\n    // Clean up\n    child.kill('SIGTERM');\n    await waitForExit(child);\n  });\n\n  it('child exits with error for invalid fd', async () => {\n    // Spawn without fd 3, passing an invalid fd so child exits with error\n    const noFdChild = spawn(TSX_BIN, [CHILD_SCRIPT, '-1'], {\n      stdio: ['ignore', 'pipe', 'pipe'],\n    });\n    child = noFdChild;\n\n    const exitCode = await waitForExit(noFdChild);\n    expect(exitCode).toBe(1);\n  });\n}, 30000);\n",
