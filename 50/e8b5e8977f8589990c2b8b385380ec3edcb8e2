            "content": "/**\n * @jest-environment node\n */\nimport { WS_SERVER_CONFIG } from '@factory/common/daemon';\n\nimport { DaemonCore } from './DaemonCore';\nimport { LOOPBACK_HOST } from './constants';\nimport { DaemonServer } from './server/daemon-server';\n\nimport type { DaemonCoreConfig } from './types';\n\njest.mock('@factory/logging', () => ({\n  ...jest.requireActual('@factory/logging'),\n  logInfo: jest.fn(),\n  logWarn: jest.fn(),\n  logException: jest.fn(),\n}));\n\njest.mock('./server/daemon-server', () => ({\n  DaemonServer: jest.fn(),\n}));\n\nconst MockDaemonServer = DaemonServer as jest.MockedClass<typeof DaemonServer>;\n\nfunction makeConfig(overrides: Partial<DaemonCoreConfig> = {}): DaemonCoreConfig {\n  return {\n    shell: '/bin/sh',\n    homeDir: '/tmp',\n    isProductionTier: false,\n    apiBaseUrl: 'http://localhost:0',\n    deploymentEnv: 'test',\n    machineId: 'test-machine',\n    terminalEnv: {},\n    ...overrides,\n  };\n}\n\nfunction mockServerInstance() {\n  const instance = {\n    start: jest.fn().mockResolvedValue(undefined),\n    stop: jest.fn().mockResolvedValue(undefined),\n    isServerRunning: jest.fn().mockReturnValue(true),\n  } as unknown as jest.Mocked<DaemonServer>;\n\n  MockDaemonServer.mockImplementation(() => instance);\n  return instance;\n}\n\nfunction capturedServerConfig(): Record<string, unknown> {\n  return MockDaemonServer.mock.calls[0]![0] as unknown as Record<string, unknown>;\n}\n\ndescribe('DaemonCore', () => {\n  beforeEach(() => {\n    jest.clearAllMocks();\n  });\n\n  // ── buildServerConfig (verified via DaemonServer constructor arg) ──\n\n  describe('buildServerConfig', () => {\n    it('uses default dev port when port/host omitted and isProductionTier=false', async () => {\n      mockServerInstance();\n      const core = new DaemonCore(makeConfig({ isProductionTier: false }));\n      await core.start();\n\n      const cfg = capturedServerConfig();\n      expect(cfg.port).toBe(WS_SERVER_CONFIG.DEFAULT_DEV_PORT);\n      expect(cfg.host).toBe(LOOPBACK_HOST);\n      expect(cfg.unix).toBeUndefined();\n    });\n\n    it('uses default prod port when port/host omitted and isProductionTier=true', async () => {\n      mockServerInstance();\n      const core = new DaemonCore(makeConfig({ isProductionTier: true }));\n      await core.start();\n\n      const cfg = capturedServerConfig();\n      expect(cfg.port).toBe(WS_SERVER_CONFIG.DEFAULT_PROD_PORT);\n      expect(cfg.host).toBe(LOOPBACK_HOST);\n    });\n\n    it('uses explicit port and host when provided', async () => {\n      mockServerInstance();\n      const core = new DaemonCore(makeConfig({ port: 9999, host: '0.0.0.0' }));\n      await core.start();\n\n      const cfg = capturedServerConfig();\n      expect(cfg.port).toBe(9999);\n      expect(cfg.host).toBe('0.0.0.0');\n    });\n\n    it('passes unix socket config when unix is set', async () => {\n      mockServerInstance();\n      const core = new DaemonCore(makeConfig({ unix: '/tmp/daemon.sock' }));\n      await core.start();\n\n      const cfg = capturedServerConfig();\n      expect(cfg.unix).toBe('/tmp/daemon.sock');\n      expect(cfg.port).toBeUndefined();\n      expect(cfg.host).toBeUndefined();\n    });\n\n    it('forwards optional fields to DaemonConfig', async () => {\n      mockServerInstance();\n      const onIdleUpdate = jest.fn();\n      const relay = { relayUrl: 'wss://relay', computerId: 'comp-1' };\n      const core = new DaemonCore(\n        makeConfig({\n          debug: true,\n          droidExecPath: '/usr/bin/droid',\n          enableCodeServer: true,\n          testingBypassTokenPassword: 'test-pw',\n          machineType: 'e2b' as never,\n          relay,\n          onIdleUpdate,\n          version: '2.0.0',\n        }),\n      );\n      await core.start();\n\n      const cfg = capturedServerConfig();\n      expect(cfg.debug).toBe(true);\n      expect(cfg.droidExecPath).toBe('/usr/bin/droid');\n      expect(cfg.enableCodeServer).toBe(true);\n      expect(cfg.testingBypassTokenPassword).toBe('test-pw');\n      expect(cfg.relay).toBe(relay);\n      expect(cfg.onIdleUpdate).toBe(onIdleUpdate);\n      expect(cfg.version).toBe('2.0.0');\n    });\n\n    it('defaults version to \"unknown\" when omitted', async () => {\n      mockServerInstance();\n      const core = new DaemonCore(makeConfig());\n      await core.start();\n\n      expect(capturedServerConfig().version).toBe('unknown');\n    });\n\n    it('defaults debug to false when omitted', async () => {\n      mockServerInstance();\n      const core = new DaemonCore(makeConfig());\n      await core.start();\n\n      expect(capturedServerConfig().debug).toBe(false);\n    });\n  });\n\n  // ── isRunning ──\n\n  describe('isRunning', () => {\n    it('returns false before start', () => {\n      const core = new DaemonCore(makeConfig());\n      expect(core.isRunning()).toBe(false);\n    });\n\n    it('returns true after start (delegates to server)', async () => {\n      const srv = mockServerInstance();\n      srv.isServerRunning.mockReturnValue(true);\n      const core = new DaemonCore(makeConfig());\n      await core.start();\n\n      expect(core.isRunning()).toBe(true);\n    });\n\n    it('returns false after stop', async () => {\n      mockServerInstance();\n      const core = new DaemonCore(makeConfig());\n      await core.start();\n      await core.stop();\n\n      expect(core.isRunning()).toBe(false);\n    });\n  });\n\n  // ── error handling ──\n\n  describe('error handling', () => {\n    it('propagates DaemonServer.start() errors', async () => {\n      const srv = mockServerInstance();\n      srv.start.mockRejectedValue(new Error('bind EADDRINUSE'));\n      const core = new DaemonCore(makeConfig());\n\n      await expect(core.start()).rejects.toThrow('bind EADDRINUSE');\n    });\n\n    it('does not leave server reference if start fails', async () => {\n      const srv = mockServerInstance();\n      srv.start.mockRejectedValue(new Error('boom'));\n      const core = new DaemonCore(makeConfig());\n\n      await expect(core.start()).rejects.toThrow();\n      // isRunning should be false since server.start threw before\n      // this.server was set (it's set before start, but isRunning\n      // delegates to server.isServerRunning which we can verify isn't called\n      // in a way that returns true)\n      expect(core.isRunning()).toBe(false);\n    });\n  });\n\n  // ── stop idempotency ──\n\n  describe('stop idempotency', () => {\n    it('stop before start is a no-op', async () => {\n      const core = new DaemonCore(makeConfig());\n      await expect(core.stop()).resolves.toBeUndefined();\n    });\n\n    it('double stop does not throw', async () => {\n      mockServerInstance();\n      const core = new DaemonCore(makeConfig());\n      await core.start();\n      await core.stop();\n      await expect(core.stop()).resolves.toBeUndefined();\n    });\n  });\n});\n",
