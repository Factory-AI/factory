            "content": "import { logWarn } from '@factory/logging';\nimport { extractRepoName } from '@factory/utils/agentReadiness';\n\nimport { getFactoryApiConfig } from './config';\nimport { fetch } from './fetch';\n\nimport type { FactoryAgentReadinessReport } from '@factory/common/agentReadiness/types';\n\n/** Number of reports to fetch per API request when paginating */\nconst PREVIOUS_REPORT_FETCH_PAGE_SIZE = 100;\n/** Maximum number of reports to search through when looking for a matching repo */\nconst PREVIOUS_REPORT_MAX_SEARCH_DEPTH = 1000;\n\n/**\n * Fetch the most recent report for the given repository URL.\n * Paginates through up to PREVIOUS_REPORT_MAX_SEARCH_DEPTH reports to find a match.\n * Matches by normalized repo name (org/repo) to handle URL variations.\n */\nexport async function fetchPreviousReadinessReport(\n  repoUrl: string\n): Promise<FactoryAgentReadinessReport | null> {\n  try {\n    const globalConfig = getFactoryApiConfig();\n    const currentRepoName = extractRepoName(repoUrl);\n\n    // Skip fetching if no auth is configured (e.g., in test scripts)\n    if (!globalConfig?.getHeaders || !currentRepoName) return null;\n\n    let startAfter: string | undefined;\n    let totalChecked = 0;\n\n    // Sequential pagination is intentional - we stop as soon as we find a match\n    while (totalChecked < PREVIOUS_REPORT_MAX_SEARCH_DEPTH) {\n      const url = startAfter\n        ? `/api/organization/agent-readiness-reports?limit=${PREVIOUS_REPORT_FETCH_PAGE_SIZE}&startAfter=${startAfter}`\n        : `/api/organization/agent-readiness-reports?limit=${PREVIOUS_REPORT_FETCH_PAGE_SIZE}`;\n\n      // eslint-disable-next-line no-await-in-loop\n      const response = await fetch(\n        url,\n        {\n          method: 'GET',\n          headers: {\n            'Content-Type': 'application/json',\n          },\n        },\n        globalConfig\n      );\n\n      // eslint-disable-next-line no-await-in-loop\n      const { reports } = (await response.json()) as {\n        reports: FactoryAgentReadinessReport[];\n      };\n\n      if (reports.length === 0) break;\n\n      // Find matching report for this repo (reports are ordered by createdAt desc)\n      const matchingReport = reports.find(\n        (r) => extractRepoName(r.repoUrl || '') === currentRepoName\n      );\n\n      if (matchingReport) return matchingReport;\n\n      totalChecked += reports.length;\n      startAfter = reports[reports.length - 1].reportId;\n\n      // Stop if we got fewer than requested (no more pages)\n      if (reports.length < PREVIOUS_REPORT_FETCH_PAGE_SIZE) break;\n    }\n\n    return null;\n  } catch (error) {\n    // Graceful degradation - continue without previous report\n    logWarn('Failed to fetch previous readiness report', { error, repoUrl });\n    return null;\n  }\n}\n",
