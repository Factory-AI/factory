{
  "name": "factory-docs-as-code",
  "private": true,
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "PATH=/opt/homebrew/opt/node@22/bin:$PATH sh tooling/dev-server.sh \"open -a 'Google Chrome' http://localhost:3333\"",
    "format": "prettier --config tooling/docs-lint/prettier.config.mjs --write \"*.{ts,js,json,yml,md}\" \"tooling/**/*.{ts,js,json,yml,md}\" \"docs/**/*.{ts,js,json,yml,md}\" \".github/*.yml\"",
    "format:check": "prettier --config tooling/docs-lint/prettier.config.mjs --check \"*.{ts,js,json,yml,md}\" \"tooling/**/*.{ts,js,json,yml,md}\" \"docs/**/*.{ts,js,json,yml,md}\" \".github/*.yml\"",
    "lint": "pnpm format:check && pnpm lint:markdownlint && pnpm lint:remark && pnpm vars:check",
    "lint:markdownlint": "pnpm --filter @factory/docs-lint exec sh -c 'cd ../.. && tooling/docs-lint/node_modules/.bin/markdownlint-cli2 --config tooling/docs-lint/markdownlint.config.mjs'",
    "lint:remark": "pnpm --filter @factory/docs-lint exec sh -c 'cd ../.. && tooling/docs-lint/node_modules/.bin/remark --rc-path tooling/docs-lint/remark.config.mjs --report ./tooling/docs-lint/remark-reporter.mjs --frail --quiet --silently-ignore --ignore-pattern \"docs/jp/**\" --ignore-pattern \"docs/snippets/**\" \"docs/**/*.mdx\"'",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "vars:build": "pnpm --filter @factory/docs-vars build",
    "vars:check": "pnpm --filter @factory/docs-vars check",
    "test:build": "node -e \"console.log('test:build scaffold: Mintlify build validation is wired in M4')\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3"
  }
}
