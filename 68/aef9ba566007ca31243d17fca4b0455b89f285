            "content": "#!/usr/bin/env node\n/**\n * Codemod: migrate file-level `slash-asterisk eslint-disable rule[, rule2] asterisk-slash`\n * block comments into per-line `// eslint-disable-next-line <rule>` directives\n * placed directly above each line where the rule actually fires.\n *\n * Why: a file-level disable silently suppresses the listed rules for every\n * line below it. Reviewers, codeowners, and `git blame` then have no way to\n * tell which lines are being suppressed -- which is exactly the failure mode\n * that masked the 15-print logging regression cited in PLT-76.\n *\n * Pipeline (per file):\n *   1. Parse the file's lines and collect every block-disable comment that\n *      has no later paired `/asterisk eslint-enable asterisk/` (these are the\n *      \"file-level / rest-of-file\" disables `factory/no-file-level-eslint-disable`\n *      flags).\n *   2. Build a working copy with those disable lines blanked out (line numbers\n *      preserved so ESLint reports stay aligned to the original file).\n *   3. Run ESLint via the Node API on the working copy. Filter results to\n *      `(line, ruleId)` pairs whose `ruleId` was named in any of the file's\n *      stripped disable headers AND whose line is at or after that disable's\n *      original position.\n *   4. Insert `// eslint-disable-next-line <rule[, rule]> -- <reason>` directly\n *      above each firing line, grouping multiple rules per line. The reason\n *      reuses the original `--` description when present, otherwise falls back\n *      to a static \"PLT-76: migrated from file-level disable\" tag.\n *   5. Re-run ESLint on the FINAL transformed source. If any of the rules the\n *      original disables listed still fire, the file is left untouched and\n *      logged so it can be handled manually.\n *\n * Idempotent: a second run finds no unpaired block disables and exits cleanly.\n */\n\nimport * as fs from 'node:fs';\nimport * as path from 'node:path';\nimport { execSync } from 'node:child_process';\n\nimport { ESLint } from 'eslint';\n\ninterface Disable {\n  lineIdx: number;\n  rules: string[];\n  description: string | null;\n}\n\ninterface FileOutcome {\n  file: string;\n  status: 'transformed' | 'no-op' | 'skipped';\n  reason?: string;\n  rulesMigrated?: string[];\n}\n\nconst REPO_ROOT = path.resolve(__dirname, '..', '..', '..', '..', '..');\n\nconst DISABLE_LINE_RE =\n  /^([ \\t]*)\\/\\*\\s*eslint-disable\\b([^*]*)\\*\\/[ \\t]*(?:\\/\\/.*)?[ \\t]*$/;\nconst ENABLE_LINE_RE =\n  /^[ \\t]*\\/\\*\\s*eslint-enable\\b[^*]*\\*\\/[ \\t]*(?:\\/\\/.*)?[ \\t]*$/;\n\nconst DEFAULT_REASON = 'PLT-76: migrated from file-level disable';\n\nfunction parseDisableInside(value: string): {\n  rules: string[];\n  description: string | null;\n} {\n  const dashIdx = value.indexOf('--');\n  const ruleText = (dashIdx >= 0 ? value.slice(0, dashIdx) : value).trim();\n  const description = dashIdx >= 0 ? value.slice(dashIdx + 2).trim() : null;\n  const rules = ruleText.length === 0 ? [] : ruleText.split(/[\\s,]+/).filter(Boolean);\n  return { rules, description };\n}\n\nfunction findUnpairedDisables(source: string): Disable[] {\n  const lines = source.split('\\n');\n  const disables: Disable[] = [];\n  const enableLineIdxs: number[] = [];\n  for (let i = 0; i < lines.length; i++) {\n    const dm = DISABLE_LINE_RE.exec(lines[i]);\n    if (dm) {\n      const { rules, description } = parseDisableInside(dm[2]);\n      disables.push({ lineIdx: i, rules, description });\n      continue;\n    }\n    if (ENABLE_LINE_RE.test(lines[i])) {\n      enableLineIdxs.push(i);\n    }\n  }\n  return disables.filter(\n    (d) => !enableLineIdxs.some((idx) => idx > d.lineIdx)\n  );\n}\n\nfunction findCandidateFiles(): string[] {\n  const cmd = String.raw`rg -l \"^[ \\t]*/\\*\\s*eslint-disable\\b\" --glob '!node_modules' --glob '!.scannerwork' --glob '!droid' --glob '!**/dist/**' --glob '!**/build/**' --glob '!**/coverage/**' --type-add 'tsx:*.tsx' --type-add 'jsx:*.jsx' --type ts --t