\n      if (!msg.ruleId) continue;\n      const matchingDisables = unpaired.filter(\n        (d) =>\n          (d.rules.length === 0 || d.rules.includes(msg.ruleId!)) &&\n          d.lineIdx <= msg.line - 1\n      );\n      if (matchingDisables.length === 0) continue;\n      const closest = matchingDisables.reduce(\n        (best, d) => (d.lineIdx > best.lineIdx ? d : best),\n        matchingDisables[0]\n      );\n      const description = closest.description ?? DEFAULT_REASON;\n      let lineMap = perLineDisables.get(msg.line);\n      if (!lineMap) {\n        lineMap = new Map();\n        perLineDisables.set(msg.line, lineMap);\n      }\n      if (!lineMap.has(msg.ruleId)) {\n        lineMap.set(msg.ruleId, description);\n      }\n    }\n\n    // Build the new source.\n    const newLines: string[] = [];\n    for (let i = 0; i < lines.length; i++) {\n      if (disableLineSet.has(i)) {\n        // Drop the original disable comment line entirely.\n        continue;\n      }\n      const lineNum = i + 1;\n      const insertions = perLineDisables.get(lineNum);\n      if (insertions && insertions.size > 0) {\n        const indent = lines[i].match(/^[ \\t]*/)![0];\n        const ruleNames = Array.from(insertions.keys()).join(', ');\n        const uniqueDescs = Array.from(\n          new Set(Array.from(insertions.values()).filter(Boolean) as string[])\n        );\n        const reason = uniqueDescs.length > 0 ? uniqueDescs.join('; ') : DEFAULT_REASON;\n        newLines.push(`${indent}// eslint-disable-next-line ${ruleNames} -- ${reason}`);\n      }\n      newLines.push(lines[i]);\n    }\n    const newSource = newLines.join('\\n');\n\n    // Write provisionally.\n    fs.writeFileSync(file, newSource);\n\n    // Verify: re-run ESLint on the final source. Any rule that was in the\n    // original disable list MUST NOT fire any longer.\n    let verifyMessages;\n    try {\n      const verifyResults = await eslint.lintText(newSource, { filePath: file });\n      verifyMessages = verifyResults[0]?.messages ?? [];\n    } catch (err) {\n      fs.writeFileSync(file, original);\n      outcomes.push({\n        file,\n        status: 'skipped',\n        reason: `verify-pass threw: ${(err as Error).message}`,\n      });\n      continue;\n    }\n\n    const allDisabledRules = new Set<string>();\n    for (const d of unpaired) {\n      for (const r of d.rules) allDisabledRules.add(r);\n    }\n    const stillFiring = verifyMessages.filter(\n      (m) =>\n        m.ruleId &&\n        m.severity === 2 &&\n        (allDisabledRules.has(m.ruleId) || allDisabledRules.size === 0)\n    );\n\n    if (stillFiring.length > 0) {\n      fs.writeFileSync(file, original);\n      const ruleHits = Array.from(\n        new Set(stillFiring.map((m) => `${m.ruleId}@${m.line}`))\n      ).join(', ');\n      outcomes.push({\n        file,\n        status: 'skipped',\n        reason: `post-codemod still firing: ${ruleHits}`,\n      });\n      continue;\n    }\n\n    const migratedRules = Array.from(allDisabledRules).sort();\n    outcomes.push({\n      file,\n      status: 'transformed',\n      rulesMigrated: migratedRules,\n    });\n  }\n\n  const transformed = outcomes.filter((o) => o.status === 'transformed');\n  const skipped = outcomes.filter((o) => o.status === 'skipped');\n  const noOps = outcomes.filter((o) => o.status === 'no-op');\n\n  console.log(`\\nTransformed: ${transformed.length}`);\n  console.log(`Skipped:     ${skipped.length}`);\n  console.log(`No-op:       ${noOps.length}`);\n\n  if (skipped.length > 0) {\n    console.log(`\\nSkipped files (require manual handling):`);\n    for (const o of skipped) {\n      console.log(`  - ${path.relative(REPO_ROOT, o.file)}`);\n      console.log(`      ${o.reason}`);\n    }\n  }\n}\n\nrun().catch((err) => {\n  console.error(err);\n  process.exit(1);\n});\n",
