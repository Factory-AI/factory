ivacyLevel as 'private' | 'organization',\n    createdBy: backend.createdBy,\n    isOwned: backend.ownerId === currentUserId,\n    forkedFrom: backend.forkedFrom,\n    isRemote: true,\n  };\n}\n\nexport function useQuerySharedAutomations(options?: { enabled?: boolean }) {\n  const { enabled = true } = options ?? {};\n  const { user, getAccessToken } = useAuth();\n\n  return useQuery({\n    queryKey: [...AUTOMATION_QUERY_KEYS.root, 'shared'],\n    queryFn: async () => {\n      const token = await getAccessToken();\n      if (!token) return [];\n\n      const response = await fetch('/api/automations?privacy=organization', {\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      if (!response.ok) return [];\n\n      const data = await response.json();\n      const automations: BackendAutomation[] = data.automations ?? [];\n\n      return automations\n        .filter((a) => a.ownerId !== user?.id)\n        .map((a) => mapBackendToAutomation(a, user?.id ?? ''));\n    },\n    enabled: enabled && !!user,\n    staleTime: 30000,\n    refetchInterval: 60000,\n  });\n}\n```\n\nWait -- check if the API URL needs to be prefixed. Look at how other API calls are made in the frontend. Check:\n- `packages/frontend/src/features/sessions/mutations/useMutateSessionPrivacy.ts`\n- Or any other file that makes API calls to the backend\n\nThe backend runs at a different port in dev. There may be a `useApi` hook or a base URL constant.\n\nAlso check `AUTOMATION_QUERY_KEYS` in the constants file to see the structure.\n\n## Task 3: Update Automations.page.tsx for dual-source merge\n\nFile: `packages/frontend/src/features/automations/pages/Automations.page.tsx`\n\nRead the full file first. Then make these changes:\n\n1. Import `useQuerySharedAutomations` from the new API queries file\n2. After fetching local automations from daemon RPC, also fetch shared automations from the backend\n3. Merge them: local automations are marked `isOwned: true`, remote shared automations (fr