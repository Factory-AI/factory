            "content": "# Rule scaffold\n\nPaste this into `packages/eslint-config/rules/<name>.js` and fill in the marked sections.\n\n```js\n/**\n * @fileoverview <one-line description of what this rule bans or requires>.\n *\n * BAD:\n *   <BAD example, copied from the ticket>\n *\n * GOOD:\n *   <GOOD example, copied from the ticket>\n *\n * Rationale:\n *   <why this matters -- prod regression, security risk, runtime crash, etc.>\n *\n * @author Factory Infrastructure Team\n */\n\n'use strict';\n\n/** @type {import('eslint').Rule.RuleModule} */\nmodule.exports = {\n  meta: {\n    // 'problem' for runtime hazards, 'suggestion' for stylistic.\n    type: 'problem',\n    docs: {\n      description:\n        '<one-sentence description shown in lint output / docs>',\n      category: 'Best Practices',\n      recommended: true,\n    },\n    // Set to 'code' only if you provide an autofix in context.report.\n    // Do NOT autofix when the fix would conflict with sibling rules\n    // (precedent: rules/no-self-package-import.js).\n    fixable: null,\n    schema: [],\n    messages: {\n      // Use messageId-keyed messages so tests stay decoupled from copy.\n      banned:\n        '<message shown to the developer when the rule fires; ' +\n        'placeholder values like {{name}} are substituted via data>',\n    },\n  },\n\n  create(context) {\n    return {\n      // Visitor functions: one per AST node type the rule cares about.\n      // CallExpression(node) { ... },\n      // MemberExpression(node) { ... },\n      // ImportDeclaration(node) { ... },\n    };\n  },\n};\n```\n\n## Optional: cross-file rule (reads other repo files)\n\nWhen the rule needs to read sibling files (e.g., a constants file) or look up the nearest `package.json`, use this pattern (copied from `rules/no-deprecated-feature-flag-references.js` and `rules/no-self-package-import.js`):\n\n```js\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\n\n// Cache lookups per directory so the rule stays cheap on large repos.\nconst cache = new Map();\nlet monorepoRootCache = null;\n\nfunction findMonorepoRoot(startPath) {\n  let dir = path.dirname(startPath);\n  while (dir !== path.dirname(dir)) {\n    try {\n      const pkg = require(path.join(dir, 'package.json'));\n      if (pkg.workspaces) return dir;\n    } catch {\n      /* keep walking */\n    }\n    dir = path.dirname(dir);\n  }\n  return null;\n}\n\nmodule.exports = {\n  meta: { /* ... */ },\n  create(context) {\n    const filename = context.getFilename();\n    const root = monorepoRootCache ?? (monorepoRootCache = findMonorepoRoot(filename));\n    if (!root) return {};\n\n    // ... read what you need from `root`, cache aggressively.\n\n    return { /* visitors */ };\n  },\n};\n\n// Export private helpers for unit testing without going through the rule.\nmodule.exports._internal = { findMonorepoRoot };\n```\n\n## Optional: file-aware rule (uses filename / path)\n\n```js\nconst filename = context.getFilename();\nconst base = path.basename(filename);\nconst isTestFile = /\\.(test|spec)\\.(ts|tsx|js|jsx|cjs|mjs)$/.test(base);\nif (isTestFile) return {}; // Skip tests when appropriate.\n```\n\n## Optional: package-aware rule (nearest package.json)\n\n```js\nfunction findPackageInfo(startDir) {\n  let dir = startDir;\n  while (dir && dir !== path.parse(dir).root) {\n    const pkgPath = path.join(dir, 'package.json');\n    if (fs.existsSync(pkgPath)) {\n      try {\n        const parsed = JSON.parse(fs.readFileSync(pkgPath, 'utf8'));\n        if (parsed && typeof parsed.name === 'string') {\n          return { name: parsed.name, dir };\n        }\n      } catch {\n        return null;\n      }\n    }\n    dir = path.dirname(dir);\n  }\n  return null;\n}\n```\n",
