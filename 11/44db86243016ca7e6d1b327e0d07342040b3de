'a.ts'),\n  errors: [{ messageId: 'selfImport' }],\n  output: null,\n},\n```\n\nDefine `FIXTURE_PKG_DIR` at the top of the file:\n\n```js\nconst path = require('path');\nconst FIXTURE_PKG_DIR = path.resolve(\n  __dirname,\n  '..',\n  'test-files',\n  'self-import-pkg',\n);\n```\n\n## Fixture packages\n\nWhen the rule reads `package.json` (e.g., to detect self-imports or workspace roots), add a fixture under `packages/eslint-config/test-files/<fixture>/package.json`. Precedent: `test-files/self-import-pkg/`. Keep the fixture minimal:\n\n```json\n{\n  \"name\": \"@factory/test-<fixture-name>\",\n  \"version\": \"0.0.0\",\n  \"private\": true,\n  \"exports\": {\n    \".\": \"./src/index.ts\"\n  }\n}\n```\n\n## Running the tests\n\nFrom the repo root:\n\n```bash\ncd packages/eslint-config && npm test -- <name>\n```\n\nOr watch mode while iterating:\n\n```bash\ncd packages/eslint-config && npm run test:watch -- <name>\n```\n\n## Asserting via messageId, not raw strings\n\nAlways:\n\n```js\nerrors: [{ messageId: 'banned' }],\n```\n\nNever:\n\n```js\nerrors: [{ message: 'Do not use ...' }],\n```\n\n`messageId`-based assertions decouple tests from message copy edits.\n",
